---
import './GridOverlay.css';
import CustomContainer from '../CustomContainer/CustomContainer.astro';
import CustomColumn from '../CustomColumn/CustomColumn.astro';
import { designTokens } from '../../config/design-tokens';
---

<grid-overlay id="grid-overlay" aria-hidden="true">
  <CustomContainer>
    {Array.from({ length: designTokens.breakpoints.lg.columns }, (_, i) => i + 1).map((num) => (
      <CustomColumn lg="1" md="1" sm="1" class={`grid-column js-col-${num}`}>
        <div class="grid-column-inner">
          {num}
        </div>
      </CustomColumn>
    ))}
  </CustomContainer>
</grid-overlay>

<script define:vars={{
  GRID_BREAKPOINTS: {
    sm: { columns: designTokens.breakpoints.sm.columns },
    md: {
      minWidth: Number.parseInt(designTokens.breakpoints.md.breakpoint, 10),
      columns: designTokens.breakpoints.md.columns,
    },
    lg: {
      minWidth: Number.parseInt(designTokens.breakpoints.lg.breakpoint, 10),
      columns: designTokens.breakpoints.lg.columns,
    },
  },
}}>
  // Toggle grid overlay with Ctrl+Shift+G or Cmd+Shift+G
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'G') {
      e.preventDefault();
      const overlay = document.getElementById('grid-overlay');
      if (overlay) {
        overlay.classList.toggle('active');
      }
    }
  });

  // Hide columns based on current breakpoint
  function updateGridColumns() {
    const width = window.innerWidth;
    let visibleColumns = GRID_BREAKPOINTS.sm.columns; // default (sm)
    
    if (width >= GRID_BREAKPOINTS.lg.minWidth) {
      visibleColumns = GRID_BREAKPOINTS.lg.columns; // lg
    } else if (width >= GRID_BREAKPOINTS.md.minWidth) {
      visibleColumns = GRID_BREAKPOINTS.md.columns; // md
    }

    // Show/hide columns based on breakpoint
    const allColumns = document.querySelectorAll('.grid-column');
    allColumns.forEach((col, index) => {
      if (index < visibleColumns) {
        if (col instanceof HTMLElement) col.style.display = 'block';
      } else {
        if (col instanceof HTMLElement) col.style.display = 'none';
      }
    });
  }

  // Update on load
  updateGridColumns();

  // Update on resize
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      updateGridColumns();
    }, 100);
  });
</script>