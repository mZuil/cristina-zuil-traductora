---
import './GridOverlay.css';
import CustomContainer from '../CustomContainer/CustomContainer.astro';
import CustomColumn from '../CustomColumn/CustomColumn.astro';
import { designTokens } from '../../config/design-tokens';

const breakpoints = {
  sm: { columns: designTokens.breakpoints.sm.columns },
  md: {
    minWidth: Number.parseInt(designTokens.breakpoints.md.breakpoint, 10),
    columns: designTokens.breakpoints.md.columns,
  },
  lg: {
    minWidth: Number.parseInt(designTokens.breakpoints.lg.breakpoint, 10),
    columns: designTokens.breakpoints.lg.columns,
  },
};
---

<grid-overlay
  id="grid-overlay"
  aria-hidden="true"
  data-breakpoints={JSON.stringify(breakpoints)}
>
  <CustomContainer>
    {Array.from({ length: designTokens.breakpoints.lg.columns }, (_, i) => i + 1).map((num) => (
      <CustomColumn lg="1" md="1" sm="1" class={`grid-column js-col-${num}`}>
        <div class="grid-column-inner">
          {num}
        </div>
      </CustomColumn>
    ))}
  </CustomContainer>
</grid-overlay>

<script>
  import { gsap } from 'gsap';

  const overlay = document.getElementById('grid-overlay');
  const GRID_BREAKPOINTS = JSON.parse(overlay?.dataset.breakpoints ?? '{}');

  let isVisible = false;

  function getVisibleColumns() {
    const width = window.innerWidth;
    if (width >= GRID_BREAKPOINTS.lg.minWidth) return GRID_BREAKPOINTS.lg.columns;
    if (width >= GRID_BREAKPOINTS.md.minWidth) return GRID_BREAKPOINTS.md.columns;
    return GRID_BREAKPOINTS.sm.columns;
  }

  function updateGridColumns() {
    const visibleColumns = getVisibleColumns();
    const allColumns = document.querySelectorAll('.grid-column');

    allColumns.forEach((col, index) => {
      if (col instanceof HTMLElement) {
        col.style.display = index < visibleColumns ? 'block' : 'none';
      }
    });
  }

  function showGrid() {
    if (!overlay) return;

    const visibleColumns = getVisibleColumns();
    const columns = [...document.querySelectorAll('.grid-column')].slice(0, visibleColumns);

    overlay.classList.add('active');
    isVisible = true;

    gsap.fromTo(
      columns,
      { y: -100, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.4,
        ease: 'power2.out',
        stagger: 0.03,
      }
    );
  }

  function hideGrid() {
    if (!overlay) return;

    const visibleColumns = getVisibleColumns();
    const columns = [...document.querySelectorAll('.grid-column')].slice(0, visibleColumns);

    isVisible = false;

    gsap.to(columns, {
      y: -100,
      opacity: 0,
      duration: 0.3,
      ease: 'power2.in',
      stagger: 0.02,
      onComplete: () => {
        overlay.classList.remove('active');
        gsap.set(columns, { y: 0, opacity: 1 });
      },
    });
  }

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'G') {
      e.preventDefault();
      isVisible ? hideGrid() : showGrid();
    }
  });

  updateGridColumns();

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(updateGridColumns, 100);
  });
</script>