---
import ComponentsFields from '../../helpers/interfaces/ComponentsFields.astro';

interface Props {
  items: any[];
  title: string;
  description?: string;
  locale?: string;
  archiveSlug: string;
  category: string;
  content: any;
  itemsCount: number;
}

const { content, itemsCount = 0 } = Astro.props;

---

<div class="archive-books">
  <ComponentsFields content={content} itemsCount={itemsCount} />
</div>