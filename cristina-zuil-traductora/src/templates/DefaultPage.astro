---
import { i18nConfig } from '../config/i18n.js';

interface Props {
  page: {
    title: string;
    content: any;
  };
}

const { page } = Astro.props;
const { title, content } = page;
---

<div class="page-content">  
  <div class="content">
    {Array.isArray(content) ? (
      content.map((block: any) => (
        <div set:html={block.body || ''} />
      ))
    ) : (
      <div set:html={content} />
    )}
  </div>
</div>