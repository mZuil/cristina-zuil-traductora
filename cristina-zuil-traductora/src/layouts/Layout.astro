---
import { ClientRouter } from 'astro:transitions';
import SEOHead from '../helpers/seo/SEOHead.astro';
import DesignTokens from '../helpers/structure/DesignTokens/DesignTokens.astro';
import { i18nConfig } from '../config/i18n';
import { getSEOData, getStructuredData } from '../utils/seo';
import BHeader from '../abemit/blocks/BHeader.astro';

//CSS Styles
import '../styles/global.scss';
import GridOverlay from '../helpers/structure/GridOverlay/GridOverlay.astro';
import BFooter from '../abemit/blocks/BFooter.astro';
import BContact from '../abemit/blocks/BContact.astro';
import PageTransition from '../helpers/page-transition/PageTransition.astro';
import BLoader from '../abemit/blocks/BLoader.astro';

interface Props {
  content: any; // Strapi content (page, book, article, etc.)
  locale?: string;
  contentType?: 'WebSite' | 'WebPage' | 'Article' | 'Book' | 'CollectionPage';
  defaultTitle?: string;
  defaultDescription?: string;
  defaultImage?: string;
}

const {
  content,
  locale = i18nConfig.defaultLocale,
  contentType = 'WebPage',
  defaultTitle,
  defaultDescription,
  defaultImage,
} = Astro.props;

// Get SEO data from Strapi content
const seoData = getSEOData(content, locale, Astro, {
  defaultTitle,
  defaultDescription,
  defaultImage,
});

// Get structured data
const structuredData = getStructuredData(content, contentType, locale, Astro);
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8"/>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <DesignTokens />
    <SEOHead seoData={seoData} />
    <ClientRouter />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData, null, 2)} />
  </head>
  <body>
    <div class="js-page-wrapper">
        <BHeader/>
          <slot />
        <BFooter />
    </div>

    <PageTransition />

    <BLoader />
    <BContact />
    <GridOverlay />
  </body>
</html>

<script>
  import '../scripts/lenis.ts';
  import '../scripts/page-transition.ts';

  // Defer the 3D model prefetch (which pulls in DRACOLoader + draco_decoder.wasm)
  // out of the critical request chain. Using a dynamic import means the Layout
  // chunk no longer statically depends on DRACOLoader, so the wasm download
  // happens after the page is idle instead of blocking LCP.
  const schedulePrefetch = () => {
    const run = () => {
      import('../scripts/model-prefetch')
        .then((m) => m.prefetchPlatformModel().catch(() => {}))
        .catch(() => {});
    };
    const ric = (window as any).requestIdleCallback as
      | ((cb: () => void, opts?: { timeout: number }) => number)
      | undefined;
    if (typeof ric === 'function') {
      ric(run, { timeout: 2000 });
    } else {
      setTimeout(run, 200);
    }
  };

  document.addEventListener("astro:page-load", () => {
    if (document.readyState === 'complete') {
      schedulePrefetch();
    } else {
      window.addEventListener('load', schedulePrefetch, { once: true });
    }
  });

  document.addEventListener("resize", () => ScrollTrigger.refresh());
</script>