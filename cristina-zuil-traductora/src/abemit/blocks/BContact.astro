---
import { uiT } from "../../config/strings-ui";
import { fetchContact } from "../../utils/api/fetchers/blocks";
import AButton from "../atoms/AButton.astro";
import AText from "../atoms/AText.astro";

const locale = Astro.currentLocale ?? "es";

const contactInfo = await fetchContact(locale);
const titleText = contactInfo.titleText;
const emailAddress = contactInfo.emailAddress;
const linkedinLink = contactInfo.linkedinLink;
const instagramLink = contactInfo.instagramLink;
---

<style lang="scss">
    @use "../../styles/mixins" as *;

    .b-contact {
        --dialog-inner-right: calc(
            var(--container-margin) + var(--width-col) + var(--grid-gutter)
        );

        &__dialog {
            border: none;
            padding: 0;
            border-radius: 18px;
            overflow: hidden;

            &::backdrop {
                background: transparent;
            }
        }

        &__dialog-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(13, 27, 42, 0.55);
            opacity: 0;
            visibility: hidden;
        }

        &__dialog-model {
            display: none;
            width: calc(var(--width-col) * 5 + var(--grid-gutter) * 4);
            height: calc(100vh - var(--grid-gutter) * 2);
            position: fixed;
            top: 50%;
            left: var(--container-margin);
            transform: translateY(-50%);
            border-radius: 30px;
            overflow: hidden;
            cursor: pointer;

            @include lg {
                display: block;
            }
        }

        &__dialog-canvas {
            width: 100%;
            height: 100%;
            display: block;
        }

        &__dialog-inner {
            width: auto;
            position: fixed;
            top: 50%;
            right: var(--grid-gutter);
            left: var(--grid-gutter);

            border-radius: 30px;
            background-color: var(--color-white);
            max-width: calc(100vw - var(--grid-gutter) * 2);
            max-height: calc(100vh - var(--grid-gutter) * 2);
            overflow: auto;
            -webkit-overflow-scrolling: touch;

            @include lg {
                width: calc(var(--width-col) * 5 + var(--grid-gutter) * 4);
                right: var(--dialog-inner-right);
                left: unset;
            }
        }

        &__dialog-body {
            padding: var(--grid-gutter);
            display: flex;
            flex-direction: column;
            gap: clamp(18px, 2vh, 60px);
        }

        &__dialog-close {
            position: absolute;
            top: 20px;
            right: 20px;
            border-radius: 50% !important;
            transition: background-color 0.3s ease-in-out;

            &:hover {
                background-color: var(--color-blue-dark);
            }
        }

        :global(.b-contact__dialog-close .a-button__inner) {
            padding: 8px !important;
        }

        &__dialog-links {
            display: flex;
            flex-direction: column;
            gap: clamp(10px, 3vh, 30px);
        }

        &__dialog-link {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(10px, 3vh, 30px);
            padding: 15px;
            background: none;
            border: none;
            border-radius: 20px;
            pointer-events: all;
            cursor: pointer;

            transition: background-color 0.3s ease-in-out;

            &:hover {
                background-color: var(--color-blue-lightest);
            }
        }

        &__link-icon {
            width: 100px;
            height: 100px;
            padding: clamp(14px, 1.6vw, 18px);
            border-radius: 50%;
            box-sizing: border-box;
            background-color: var(--color-blue-default);
            color: var(--color-white);
        }

        &__dialog-background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 1;
        }

        @media (max-height: 780px), (max-width: 900px) {
            &__dialog-link {
                flex-direction: row;
                align-items: center;
                justify-content: flex-start;
                padding: 12px;
            }

            &__link-icon {
                width: 72px;
                height: 72px;
                padding: 14px;
                flex: 0 0 auto;
            }
        }

        &__link-text {
            font-weight: 400;
            color: var(--color-grey);
            user-select: text;
        }

        &__copy-icon {
            margin-bottom: -3px;
            color: var(--color-grey);
        }
    }
</style>

<div class="b-contact js-b-contact" data-locale={locale}>
    <dialog class="b-contact__dialog js-contact-dialog" data-dialog aria-label={titleText}>
        <div class="b-contact__dialog-backdrop | js-dialog-backdrop"></div>
        <div class="b-contact__dialog-model | js-dialog-model">
            <canvas class="b-contact__dialog-canvas | js-dialog-canvas"></canvas>
        </div>
        <div class="b-contact__dialog-inner | js-dialog-inner">
            <AButton type="button" variant="primary" class="b-contact__dialog-close" data-dialog-close>
                <svg xmlns="http://www.w3.org/2000/svg" width="24px" height="24px" viewBox="0 -960 960 960" fill="currentColor"><path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"></path></svg>
            </AButton>
            <div class="b-contact__dialog-body">
                <AText size="headline-1">{titleText}</AText>
                <div class="b-contact__dialog-links">
                    <AButton type="button" class="b-contact__dialog-link" data-copy-email={emailAddress}>
                        <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 0 24 24" width="24px" fill="currentColor" class="b-contact__link-icon">
                            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"></path>
                        </svg>
                        <AText size="headline-2">
                            {uiT(Astro.currentLocale, "contactEmail")}: <span class="b-contact__link-text">{emailAddress}</span>
                        </AText>
                    </AButton>
                    <AButton as="a" class="b-contact__dialog-link" href={linkedinLink?.url} target="_blank">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="b-contact__link-icon">
                            <path d="M20.9 20.9H17.166V15.053C17.166 13.659 17.138 11.865 15.222 11.865C13.277 11.865 12.98 13.382 12.98 14.95V20.9H9.249V8.87699H12.833V10.516H12.881C13.2402 9.90278 13.7588 9.39838 14.3818 9.05643C15.0048 8.71447 15.7088 8.54775 16.419 8.57399C20.199 8.57399 20.898 11.062 20.898 14.3V20.9H20.9ZM5.036 7.23199C4.60732 7.23259 4.1881 7.10603 3.83137 6.86832C3.47463 6.63061 3.19641 6.29244 3.03191 5.89658C2.8674 5.50072 2.824 5.06497 2.9072 4.64444C2.99039 4.22392 3.19644 3.83751 3.49928 3.53411C3.80212 3.23071 4.18815 3.02395 4.60852 2.93998C5.02889 2.85601 5.46473 2.8986 5.86089 3.06237C6.25705 3.22615 6.59573 3.50374 6.8341 3.86003C7.07246 4.21633 7.1998 4.63532 7.2 5.06399C7.20039 5.34847 7.14472 5.63024 7.03615 5.89319C6.92759 6.15615 6.76827 6.39512 6.5673 6.59647C6.36633 6.79781 6.12764 6.95757 5.86489 7.06662C5.60214 7.17567 5.32048 7.23186 5.036 7.23199ZM6.906 20.9H3.165V8.87699H6.906V20.9Z" fill="currentColor"></path>
                        </svg>
                        <AText size="headline-2">
                            {uiT(Astro.currentLocale, "linkedin")}: <span class="b-contact__link-text">{linkedinLink?.label}</span>
                        </AText>
                    </AButton>
                    <AButton as="a" class="b-contact__dialog-link" href={instagramLink?.url} target="_blank">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="b-contact__link-icon">
                            <path d="M21.94 7.88C21.9206 7.0503 21.7652 6.2294 21.48 5.45C21.2283 4.78181 20.8322 4.17742 20.32 3.68C19.8226 3.16776 19.2182 2.77166 18.55 2.52C17.7706 2.23484 16.9497 2.07945 16.12 2.06C15.06 2 14.72 2 12 2C9.28 2 8.94 2 7.88 2.06C7.0503 2.07945 6.2294 2.23484 5.45 2.52C4.78181 2.77166 4.17742 3.16776 3.68 3.68C3.16743 4.17518 2.77418 4.78044 2.53 5.45C2.23616 6.22734 2.07721 7.04915 2.06 7.88C2 8.94 2 9.28 2 12C2 14.72 2 15.06 2.06 16.12C2.07721 16.9508 2.23616 17.7727 2.53 18.55C2.77418 19.2196 3.16743 19.8248 3.68 20.32C4.17742 20.8322 4.78181 21.2283 5.45 21.48C6.2294 21.7652 7.0503 21.9206 7.88 21.94C8.94 22 9.28 22 12 22C14.72 22 15.06 22 16.12 21.94C16.9497 21.9206 17.7706 21.7652 18.55 21.48C19.2134 21.219 19.816 20.8242 20.3201 20.3201C20.8242 19.816 21.219 19.2134 21.48 18.55C21.7652 17.7706 21.9206 16.9497 21.94 16.12C21.94 15.06 22 14.72 22 12C22 9.28 22 8.94 21.94 7.88ZM20.14 16C20.1327 16.6348 20.0178 17.2637 19.8 17.86C19.6327 18.2913 19.3773 18.683 19.0501 19.0101C18.723 19.3373 18.3313 19.5927 17.9 19.76C17.3037 19.9778 16.6748 20.0927 16.04 20.1C15.04 20.15 14.67 20.16 12.04 20.16C9.41 20.16 9.04 20.16 8.04 20.1C7.38073 20.1148 6.72401 20.0132 6.1 19.8C5.66869 19.6327 5.27698 19.3773 4.94985 19.0501C4.62272 18.723 4.36734 18.3313 4.2 17.9C3.97775 17.2911 3.86271 16.6482 3.86 16C3.86 15 3.8 14.63 3.8 12C3.8 9.37 3.8 9 3.86 8C3.86271 7.35178 3.97775 6.70893 4.2 6.1C4.36734 5.66869 4.62272 5.27698 4.94985 4.94985C5.27698 4.62272 5.66869 4.36734 6.1 4.2C6.70893 3.97775 7.35178 3.86271 8 3.86C9 3.86 9.37 3.8 12 3.8C14.63 3.8 15 3.8 16 3.86C16.6348 3.86728 17.2637 3.98225 17.86 4.2C18.2913 4.36734 18.683 4.62272 19.0101 4.94985C19.3373 5.27698 19.5927 5.66869 19.76 6.1C19.9959 6.7065 20.1245 7.34942 20.14 8C20.19 9 20.2 9.37 20.2 12C20.2 14.63 20.19 15 20.14 16Z" fill="currentColor"></path>
                            <path d="M12 6.86C10.9834 6.86 9.98964 7.16146 9.14437 7.72625C8.2991 8.29104 7.64029 9.0938 7.25126 10.033C6.86222 10.9722 6.76044 12.0057 6.95876 13.0028C7.15709 13.9998 7.64663 14.9157 8.36547 15.6345C9.08431 16.3534 10.0002 16.8429 10.9972 17.0412C11.9943 17.2396 13.0278 17.1378 13.967 16.7487C14.9062 16.3597 15.709 15.7009 16.2738 14.8556C16.8385 14.0104 17.14 13.0166 17.14 12C17.14 10.6368 16.5985 9.32941 15.6345 8.36547C14.6706 7.40153 13.3632 6.86 12 6.86ZM12 15.33C11.3414 15.33 10.6976 15.1347 10.15 14.7688C9.60234 14.4029 9.17552 13.8828 8.92348 13.2743C8.67144 12.6659 8.6055 11.9963 8.73399 11.3503C8.86247 10.7044 9.17963 10.111 9.64533 9.64533C10.111 9.17963 10.7044 8.86247 11.3503 8.73399C11.9963 8.6055 12.6659 8.67144 13.2743 8.92348C13.8828 9.17552 14.4029 9.60234 14.7688 10.15C15.1347 10.6976 15.33 11.3414 15.33 12C15.33 12.4373 15.2439 12.8703 15.0765 13.2743C14.9092 13.6784 14.6639 14.0454 14.3547 14.3547C14.0454 14.6639 13.6784 14.9092 13.2743 15.0765C12.8703 15.2439 12.4373 15.33 12 15.33Z" fill="currentColor"></path>
                            <path d="M17.34 5.46001C17.1027 5.46001 16.8707 5.53039 16.6733 5.66224C16.476 5.7941 16.3222 5.98152 16.2313 6.20079C16.1405 6.42006 16.1168 6.66134 16.1631 6.89411C16.2094 7.12689 16.3236 7.34071 16.4915 7.50853C16.6593 7.67636 16.8731 7.79065 17.1059 7.83695C17.3387 7.88325 17.5799 7.85949 17.7992 7.76866C18.0185 7.67784 18.2059 7.52403 18.3378 7.32669C18.4696 7.12935 18.54 6.89734 18.54 6.66001C18.54 6.34175 18.4136 6.03652 18.1885 5.81148C17.9635 5.58643 17.6583 5.46001 17.34 5.46001Z" fill="currentColor"></path>
                        </svg>
                        <AText size="headline-2">
                            {uiT(Astro.currentLocale, "instagram")}: <span class="b-contact__link-text">{instagramLink?.label}</span>
                        </AText>
                    </AButton>
                </div>
            </div>
        </div>
    </dialog>
</div>

<script>
    import { gsap } from "gsap";
    import { MorphSVGPlugin } from "gsap/MorphSVGPlugin";
    import * as THREE from "three";
    import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";
    import { DRACOLoader } from "three/examples/jsm/loaders/DRACOLoader.js";
    import { RoomEnvironment } from "three/examples/jsm/environments/RoomEnvironment.js";

    gsap.registerPlugin(MorphSVGPlugin);

    declare global {
        interface Window {
            openContactModal?: () => void;
        }
    }

    const MORPH_TARGET = "M5 21q-.825 0-1.4125-.5875T3 19v-14q0-.825.5875-1.4125T5 3h7v2H5v14h14v-7h2v7q0 .825-.5875 1.4125T19 21H5Zm4.7-5.3-1.4-1.4 9.3-9.3H14v-2h7v7h-2v-3.6L9.7 15.7Z";

    const setLenisEnabled = (enabled: boolean): void => {
        const lenis = (window as any).__lenis as
            | { stop?: () => void; start?: () => void }
            | undefined;
        if (!lenis) return;
        if (enabled) lenis.start?.();
        else lenis.stop?.();
    };

    const initAll = () => {
        const nodeInDOM = document.querySelector<HTMLElement>(".js-b-contact");
        if (!nodeInDOM) return;
        if (nodeInDOM.dataset.contactInit === "1") return;
        nodeInDOM.dataset.contactInit = "1";

        const dialog = nodeInDOM.querySelector("dialog[data-dialog]");
        if (!(dialog instanceof HTMLDialogElement)) return;

        const dialogPanel = dialog.querySelector<HTMLElement>(".js-dialog-inner");
        const dialogBackdrop = dialog.querySelector<HTMLElement>(".js-dialog-backdrop");
        const closeBtn = dialog.querySelector<HTMLElement>("[data-dialog-close]");
        const dialogModel = dialog.querySelector<HTMLElement>(".js-dialog-model");
        const dialogCanvas = dialog.querySelector<HTMLCanvasElement>(".js-dialog-canvas");
        if (!dialogPanel) return;

        // ── Three.js state ────────────────────────────────────────────────────
        let threeInit = false;
        let renderer: any = null;
        let scene: any = null;
        let camera: any = null;
        let mailboxPivot: any = null;
        let mailbox: any = null;
        let mixer: any = null;
        let clickClip: any = null;
        let clickAction: any = null;
        let lastFrameTimeMs: number | null = null;
        let frameId: number | null = null;
        let ro: ResizeObserver | null = null;
        let clickAnimation: gsap.core.Timeline | null = null;

        let onModelPointerMove: ((e: PointerEvent) => void) | null = null;
        let onModelPointerLeave: (() => void) | null = null;
        let onWindowPointerMove: ((e: PointerEvent) => void) | null = null;
        let onWindowPointerReset: (() => void) | null = null;
        let onWindowResize: (() => void) | null = null;
        const basePivotRot = new THREE.Vector2(0, 0);
        const targetPivotRot = new THREE.Vector2(0, 0);

        const stopRenderLoop = (): void => {
            if (frameId != null) {
                cancelAnimationFrame(frameId);
                frameId = null;
            }
        };

        const renderThree = (): void => {
            if (!renderer || !scene || !camera) return;
            const nowMs = performance.now();
            const deltaSeconds =
                lastFrameTimeMs == null ? 0 : Math.max(0, (nowMs - lastFrameTimeMs) / 1000);
            lastFrameTimeMs = nowMs;
            mixer?.update(deltaSeconds);

            if (mailboxPivot) {
                const lerpFactor = 0.08;
                mailboxPivot.rotation.x += (targetPivotRot.x - mailboxPivot.rotation.x) * lerpFactor;
                mailboxPivot.rotation.y += (targetPivotRot.y - mailboxPivot.rotation.y) * lerpFactor;
            }

            renderer.render(scene, camera);
            frameId = requestAnimationFrame(renderThree);
        };

        const resizeRendererToContainer = (): void => {
            if (!renderer || !camera || !dialogModel) return;
            const rect = dialogModel.getBoundingClientRect();
            const width = Math.max(1, Math.floor(rect.width));
            const height = Math.max(1, Math.floor(rect.height));
            if (width <= 1 || height <= 1) {
                return;
            }
            renderer.setSize(width, height, false);
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
        };

        // ── Viewport-dependent mailbox scale + vertical position ──────────────
        // Ranges: 700px (small laptop) → 1956px (large screen)
        // Scale:      0.30 → 0.20
        // Position Y: -0.10 → 0.15  (lower on smaller screens)
        const updateMailboxForViewport = (): void => {
            if (!mailbox) return;
            const minH = 700, maxH = 1956;
            const t = Math.max(0, Math.min(1, (window.innerHeight - minH) / (maxH - minH)));
            const scale = 0.25 + (0.20 - 0.30) * t;
            mailbox.scale.set(scale, scale, scale);
            mailbox.position.y = -0.10 + (0.15 - (-0.10)) * t;
        };

        const initThreeOnce = async (): Promise<void> => {
            if (threeInit) return;
            if (!dialogModel || !dialogCanvas) return;
            threeInit = true;

            renderer = new THREE.WebGLRenderer({
                canvas: dialogCanvas,
                antialias: true,
                alpha: true,
                powerPreference: "high-performance",
            });
            renderer.setPixelRatio(Math.min(2, window.devicePixelRatio || 1));
            renderer.outputColorSpace = THREE.SRGBColorSpace;
            renderer.toneMapping = THREE.ACESFilmicToneMapping;
            renderer.toneMappingExposure = 0.8;

            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(80, 1, 0.1, 100);
            camera.position.set(0, 0, 2.5);

            const pmremGenerator = new THREE.PMREMGenerator(renderer);
            scene.environment = pmremGenerator.fromScene(new RoomEnvironment(), 0.04).texture;
            pmremGenerator.dispose();

            const ambient = new THREE.AmbientLight(0xffffff, 0.35);
            const key = new THREE.DirectionalLight(0xffffff, 2.0);
            key.position.set(2, 3, 4);
            scene.add(ambient, key);

            const dracoLoader = new DRACOLoader();
            dracoLoader.setDecoderPath("/draco/");

            const loader = new GLTFLoader();
            loader.setDRACOLoader(dracoLoader);

            const gltf = await loader.loadAsync("/models/mailbox.glb");
            mailbox = gltf.scene;
            mailbox.rotation.x = Math.PI / 8;
            mailbox.rotation.y = Math.PI / 2 + Math.PI / 8;

            // Scale and position.y are set via updateMailboxForViewport()
            updateMailboxForViewport();

            mailboxPivot = new THREE.Object3D();
            mailboxPivot.add(mailbox);
            scene.add(mailboxPivot);

            basePivotRot.set(mailboxPivot.rotation.x, mailboxPivot.rotation.y);
            targetPivotRot.set(mailboxPivot.rotation.x, mailboxPivot.rotation.y);

            camera.lookAt(0, 1, 0);

            lastFrameTimeMs = null;

            if (gltf.animations && gltf.animations.length > 0) {
                clickClip = gltf.animations[0];
                mixer = new THREE.AnimationMixer(mailbox);
                clickAction = mixer.clipAction(clickClip);
                clickAction.loop = THREE.LoopOnce;
                clickAction.clampWhenFinished = true;
            }

            // Mouse-follow rotation is driven by window pointer events while the dialog is open.
            onWindowPointerMove = (e: PointerEvent) => {
                if (!mailboxPivot) return;
                const w = Math.max(1, window.innerWidth);
                const h = Math.max(1, window.innerHeight);
                const nx = (e.clientX / w) * 2 - 1;
                const ny = (e.clientY / h) * 2 - 1;

                const maxYaw = 0.35;
                const maxPitch = 0.18;

                targetPivotRot.y = basePivotRot.y + nx * maxYaw;
                targetPivotRot.x = basePivotRot.x + ny * maxPitch;
            };

            onWindowPointerReset = () => {
                targetPivotRot.x = basePivotRot.x;
                targetPivotRot.y = basePivotRot.y;
            };
        };

        const destroyThree = (): void => {
            stopRenderLoop();
            ro?.disconnect();
            ro = null;
            clickAnimation?.kill();
            clickAnimation = null;

            if (onWindowResize) {
                window.removeEventListener("resize", onWindowResize);
                onWindowResize = null;
            }

            if (dialogModel) {
                if (onModelPointerMove) {
                    dialogModel.removeEventListener("pointermove", onModelPointerMove);
                }
                if (onModelPointerLeave) {
                    dialogModel.removeEventListener("pointerleave", onModelPointerLeave);
                }
            }
            onModelPointerMove = null;
            onModelPointerLeave = null;

            if (onWindowPointerMove) {
                window.removeEventListener("pointermove", onWindowPointerMove);
            }
            if (onWindowPointerReset) {
                window.removeEventListener("blur", onWindowPointerReset);
            }
            onWindowPointerMove = null;
            onWindowPointerReset = null;

            if (scene) {
                scene.traverse((obj: any) => {
                    if (obj instanceof THREE.Mesh) {
                        obj.geometry.dispose();
                        const mats = Array.isArray(obj.material)
                            ? obj.material
                            : [obj.material];
                        mats.forEach((m: any) => m.dispose());
                    }
                });
            }

            renderer?.dispose();
            renderer?.forceContextLoss();
            renderer = null;
            scene = null;
            camera = null;
            mailboxPivot = null;
            mailbox = null;
            threeInit = false;
        };

        // Clean up before Astro swaps the page (View Transitions)
        document.addEventListener("astro:before-swap", destroyThree);

        // ── Click animation on the model panel ───────────────────────────────
        dialogModel?.addEventListener("click", () => {
            if (!mailbox) return;

            if (clickAction && clickClip) {
                clickAnimation?.kill();
                clickAnimation = null;

                clickAction.reset();
                clickAction.enabled = true;
                clickAction.setEffectiveTimeScale(1);
                clickAction.setEffectiveWeight(1);
                clickAction.play();
                return;
            }
        });

        // ── Dialog open / close ───────────────────────────────────────────────
        let dialogTween: gsap.core.Tween | null = null;
        let modelTween: gsap.core.Tween | null = null;
        const killDialogTween = (): void => {
            dialogTween?.kill();
            dialogTween = null;
            modelTween?.kill();
            modelTween = null;
        };

        const openDialog = (): void => {
            killDialogTween();
            if (dialog.open) dialog.close();
            dialog.showModal();

            document.dispatchEvent(new CustomEvent("articles-modal:open"));
            setLenisEnabled(false);
            document.body.classList.add("is-overflow-hidden");

            const rightInnerDialog = getComputedStyle(document.documentElement)
                .getPropertyValue("--dialog-inner-right");

            if (dialogBackdrop) {
                gsap.killTweensOf(dialogBackdrop);
                gsap.set(dialogBackdrop, { autoAlpha: 0 });
                gsap.to(dialogBackdrop, {
                    autoAlpha: 1,
                    duration: 0.25,
                    ease: "power1.out",
                });
            }

            gsap.set(dialogPanel, {
                x: rightInnerDialog,
                yPercent: -50,
                scale: 0.85,
                autoAlpha: 0,
                transformOrigin: "50% 50%",
            });

            if (dialogModel && getComputedStyle(dialogModel).display !== "none") {
                gsap.set(dialogModel, { autoAlpha: 0 });
                modelTween = gsap.to(dialogModel, {
                    autoAlpha: 1,
                    duration: 0.4,
                    ease: "power1.out",
                });
            }

            dialogTween = gsap.to(dialogPanel, {
                scale: 1,
                autoAlpha: 1,
                duration: 0.5,
                ease: "back.out(1.7)",
            });

            // Double rAF ensures the dialog is painted and has real dimensions
            // before Three.js reads getBoundingClientRect
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    initThreeOnce()
                        .then(() => {
                            stopRenderLoop();
                            lastFrameTimeMs = null;
                            const waitForNonZeroSize = (maxFrames = 60): Promise<void> => {
                                return new Promise((resolve) => {
                                    let frames = 0;
                                    const tick = () => {
                                        if (!dialogModel) return resolve();
                                        const rect = dialogModel.getBoundingClientRect();
                                        if (rect.width > 1 && rect.height > 1) return resolve();
                                        frames += 1;
                                        if (frames >= maxFrames) return resolve();
                                        requestAnimationFrame(tick);
                                    };
                                    requestAnimationFrame(tick);
                                });
                            };
                            waitForNonZeroSize().then(() => {
                                resizeRendererToContainer();
                                renderThree();
                            });

                            // ResizeObserver: reacts to the panel element changing size
                            if (dialogModel && !ro) {
                                ro = new ResizeObserver(() => {
                                    const rect = dialogModel.getBoundingClientRect();
                                    const width = Math.max(1, Math.floor(rect.width));
                                    const height = Math.max(1, Math.floor(rect.height));
                                    if (width <= 1 || height <= 1) {
                                        return;
                                    }
                                    resizeRendererToContainer();
                                });
                                ro.observe(dialogModel);
                            }

                            // Window resize: updates canvas size + mailbox scale/position
                            onWindowResize = () => {
                                resizeRendererToContainer();
                                updateMailboxForViewport();
                            };
                            window.addEventListener("resize", onWindowResize);

                            if (onWindowPointerMove) {
                                window.addEventListener("pointermove", onWindowPointerMove);
                            }
                            if (onWindowPointerReset) {
                                window.addEventListener("blur", onWindowPointerReset);
                            }
                        })
                        .catch((err) => {
                            console.error("[BContact] Three.js init failed:", err);
                            stopRenderLoop();
                        });
                });
            });
        };

        const closeDialog = (): void => {
            if (!dialog.open) return;
            killDialogTween();
            stopRenderLoop();

            if (onWindowResize) {
                window.removeEventListener("resize", onWindowResize);
                onWindowResize = null;
            }

            if (onWindowPointerMove) {
                window.removeEventListener("pointermove", onWindowPointerMove);
            }
            if (onWindowPointerReset) {
                window.removeEventListener("blur", onWindowPointerReset);
            }

            if (dialogModel && getComputedStyle(dialogModel).display !== "none") {
                modelTween = gsap.to(dialogModel, {
                    autoAlpha: 0,
                    duration: 0.2,
                    ease: "power1.in",
                });
            }

            if (dialogBackdrop) {
                gsap.killTweensOf(dialogBackdrop);
                gsap.to(dialogBackdrop, {
                    autoAlpha: 0,
                    duration: 0.2,
                    ease: "power1.in",
                });
            }

            dialogTween = gsap.to(dialogPanel, {
                scale: 0.85,
                autoAlpha: 0,
                duration: 0.3,
                ease: "back.in(1.7)",
                onComplete: () => {
                    dialog.close();
                    gsap.set(dialogPanel, { clearProps: "all" });
                    if (dialogBackdrop) {
                        gsap.set(dialogBackdrop, { autoAlpha: 0, clearProps: "all" });
                    }
                    setLenisEnabled(true);
                    document.body.classList.remove("is-overflow-hidden");
                    document.dispatchEvent(new CustomEvent("articles-modal:close"));
                },
            });
        };

        window.openContactModal = openDialog;

        // ── Email copy to clipboard ───────────────────────────────────────────
        const emailBtn = nodeInDOM.querySelector<HTMLElement>("[data-copy-email]");
        if (emailBtn) {
            emailBtn.addEventListener("click", () => {
                const email = emailBtn.dataset.copyEmail ?? "";
                if (!email) return;
                window.location.href = `mailto:${encodeURIComponent(email)}`;
            });
        }

        closeBtn?.addEventListener("click", () => closeDialog());
        dialogBackdrop?.addEventListener("click", () => closeDialog());
        dialog.addEventListener("click", (e) => {
            if (e.target === dialog) closeDialog();
        });
        dialog.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
                e.preventDefault();
                closeDialog();
            }
        });
        dialog.addEventListener("close", () => {
            if (dialogBackdrop) {
                gsap.set(dialogBackdrop, { autoAlpha: 0, clearProps: "all" });
            }
            setLenisEnabled(true);
            document.body.classList.remove("is-overflow-hidden");
            document.dispatchEvent(new CustomEvent("articles-modal:close"));
            stopRenderLoop();
        });

        // ── MorphSVG icon hover ───────────────────────────────────────────────
        const links = nodeInDOM.querySelectorAll<HTMLElement>(".b-contact__dialog-link");

        links.forEach((link) => {
            const icon = link.querySelector<SVGElement>(".b-contact__link-icon");
            if (!icon) return;

            const paths = Array.from(icon.querySelectorAll<SVGPathElement>("path"));
            if (!paths.length) return;

            const primaryPath = paths[0];
            const extraPaths = paths.slice(1);
            const originalD = primaryPath.getAttribute("d") ?? "";

            let morphTween: gsap.core.Tween | null = null;

            link.addEventListener("mouseenter", () => {
                morphTween?.kill();

                if (extraPaths.length) {
                    gsap.to(extraPaths, {
                        opacity: 0,
                        duration: 0.15,
                        ease: "power1.in",
                    });
                }

                morphTween = gsap.to(primaryPath, {
                    morphSVG: MORPH_TARGET,
                    duration: 0.45,
                    ease: "power2.inOut",
                });
            });

            link.addEventListener("mouseleave", () => {
                morphTween?.kill();

                morphTween = gsap.to(primaryPath, {
                    morphSVG: originalD,
                    duration: 0.45,
                    ease: "power2.inOut",
                });

                if (extraPaths.length) {
                    gsap.to(extraPaths, {
                        opacity: 1,
                        duration: 0.2,
                        delay: 0.3,
                        ease: "power1.out",
                    });
                }
            });
        });
    };

    initAll();
    document.addEventListener("astro:page-load", initAll);
</script>