---
import AText from "../atoms/AText.astro";
import { fetchFooter } from "../../utils/api/fetchers/blocks";

const locale = Astro.currentLocale ?? "es";

let copyrightText = "";

const footer = await fetchFooter(locale);
copyrightText = footer.copyrightText;

---

<style lang="scss">
    @use "../../styles/mixins" as *;

    .b-footer {
        @include use-font(menu-item);

        position: relative;
        background-color: var(--color-white);
        z-index: 1;

        margin-top: auto;
        margin-bottom: -1px;

        &__text {
            padding-block: 20px 15px;
            color: var(--color-grey);
            text-align: center;
        }
    }
</style>

<footer class="b-footer js-footer">
    <AText as="p" size="small-text" class="b-footer__text">{copyrightText}</AText>
</footer>