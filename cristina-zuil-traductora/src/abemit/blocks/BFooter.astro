---
import AText from "../atoms/AText.astro";
import { fetchFooter } from "../../utils/api/fetchers/blocks";
import { blocksToHtml } from "../../utils/blocksToHtml";

const locale = Astro.currentLocale ?? "es";

const footer = await fetchFooter(locale);
const copyrightHtml = blocksToHtml(footer.copyrightTextBlock);

---

<style lang="scss">
    @use "../../styles/mixins" as *;

    .b-footer {
        @include use-font(menu-item);

        $selector: &;

        position: relative;
        background-color: var(--color-white);
        z-index: 1;

        margin-top: auto;
        margin-bottom: -1px;

        &__text {
            padding-block: 20px 15px;
            color: var(--color-grey);
            text-align: center;

            @include sm {
                padding-inline: 5px;
            }
        }

        :global(#{$selector}__text a) {
            color: var(--color-white);
            text-decoration: none;
            background-image: linear-gradient(currentColor, currentColor);
            background-repeat: no-repeat;
            background-position: 0 100%;
            background-size: 0% 1px;
            transition: background-size 0.3s ease;

            &:hover,
            &:focus-visible {
                background-size: 100% 1px;
            }
        }
    }
</style>

<footer class="b-footer js-footer">
    <AText as="div" size="small-text" class="b-footer__text" html={copyrightHtml} />
</footer>