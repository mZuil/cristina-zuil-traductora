---
import type { Publisher } from "../../helpers/interfaces/Publisher.astro";
import AImage from "../atoms/AImage.astro";
import type { StrapiImage } from "../../helpers/interfaces/StrapiImage";
import AText from "../atoms/AText.astro";

interface Props {
    publishers: Publisher[];
}

const { publishers = [] } = Astro.props as Props;

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL ?? "";

const getStrapiImageFromLogo = (logo: Publisher['logo']): StrapiImage | null => {
  if (!logo || typeof logo === 'string') return null;

  const imgAttr =
    (logo as any)?.data?.attributes ??
    (logo as any)?.attributes ??
    logo;

  if (!imgAttr) return null;
  if (typeof imgAttr?.url !== 'string' || !imgAttr.url) return null;
  if (typeof imgAttr?.width !== 'number' || typeof imgAttr?.height !== 'number') return null;
  if (typeof imgAttr?.mime !== 'string' || !imgAttr.mime) return null;
  return imgAttr as StrapiImage;
};

const getAbsoluteUrl = (raw: string): string => {
  if (!raw) return '';
  if (raw.startsWith('http://') || raw.startsWith('https://')) return raw;
  return `${STRAPI_URL}${raw}`;
};
---

<style lang="scss">
    @use "../../styles/mixins" as *;

    .c-logos {

        $self: &;

        position: relative;
        display: flex;
        flex-direction: row;
        gap: 52px;
        background-color: var(--color-white);
        z-index: 1;

        &__item {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            width: 156px;
            text-decoration: none;
            position: relative; // needed for the pseudo-element

            // Tint overlay
            &::after {
                content: '';
                position: absolute;
                inset: 0;
                background-color: var(--color-blue-dark); // use your brand blue
                mix-blend-mode: color; //replaces hue, keeps luminosity
                pointer-events: none; //so clicks still reach the <a>
                opacity: 1;
                transition: opacity 200ms ease-in-out;
            }

            &:hover, &:focus-visible {
                &::after {
                    opacity: 0; // reveal original color on hover (optional)
                }

                #{$self}__item-text {
                    opacity: 1;
                    visibility: visible;
                }
            }
        }

        &__item-text {
           width: 100%;
           opacity: 0;
           visibility: hidden;
           text-align: center;
           text-decoration: none;
           font-weight: 700;
           padding-top: 20px;
           color: var(--color-blue-dark);

           transition: opacity 200ms ease-in-out;
        }
    }

    .c-logos__item :global(img),
    .c-logos__item :global(.a-image) {
        width: auto;
        height: 150px;
        max-width: 156px;
        object-fit: contain;

        display: block;
    }

</style>

<section class="c-logos js-c-logos">
    {
        publishers.map((publisher) => {
            const logoImage = getStrapiImageFromLogo(publisher.logo);
            const logoUrl = typeof publisher.logo === 'string' ? publisher.logo : '';
            const absoluteUrl = logoUrl ? getAbsoluteUrl(logoUrl) : '';

            return (
            <a href={publisher.link?.url || ''} target="_blank" class="c-logos__item">
                {logoImage ? (
                  <AImage image={logoImage} sizes="156px" loading="lazy" />
                ) : (
                  <img src={absoluteUrl} alt={publisher.name} />
                )}
                <AText tag="p" size="small-text" class="c-logos__item-text">
                  {publisher.name}
                </AText>
            </a>
            );
        })
    }
</section>

<script>
  import { BaseComponent } from "../../helpers/base/BaseComponent";

  class CLogos extends BaseComponent {
    constructor(nodeInDOM: HTMLElement) {
      super(nodeInDOM);
    }
  }

  function initLogos() {
    BaseComponent.mountAll(".js-c-logos", CLogos);
  }

  document.addEventListener("astro:page-load", initLogos);
</script>