---
// src/components/organisms/CFilters.astro
import CustomColumn from '../../helpers/structure/CustomColumn/CustomColumn.astro';
import CustomContainer from '../../helpers/structure/CustomContainer/CustomContainer.astro';
import { uiT } from '../../config/strings-ui';
import ASelect from '../atoms/ASelect.astro';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

---

<style lang="scss">
  @use '../../styles/mixins.scss' as *;
  
  .c-filters {

    position: relative;
    background-color: var(--color-white);
    z-index: 2; //For the selector to be over the next component

    &__search-wrap {
      position: relative;
      flex: 1 1 260px;
    }

    &__search-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      color: var(--color-blue-dark);
    }

    &__input {
      @include use-font("small-text");

      width: 100%;
      padding: 8px 16px 8px 42px;
      border: 2px solid var(--color-blue-light);
      border-radius: 10px;
      transition: border-color 0.2s;

      &:focus {
        outline: none;
        border-color: var(--color-blue-dark);
      }

      &::placeholder {
        color: var(--color-grey);
      }
    }

    &__select-wrap {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding-top: 35px;
    }

    &__label {
      @include use-font("tagline");
    }
  }
</style>

<div class="c-filters" data-locale={locale}>
  <CustomContainer>
    <CustomColumn lg-push="2" lg="8" md="8" sm="4">
      <div class="c-filters__search-wrap">
        <svg class="c-filters__search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input id="books-search" class="c-filters__input" type="search" placeholder={uiT(locale, 'searchPlaceholder')} autocomplete="off" />
      </div>
    </CustomColumn>
    <CustomColumn lg-push="2" lg="4" md="4" sm="4">
      <div class="c-filters__select-wrap">
        <label for="books-genre" class="c-filters__label">{uiT(locale, 'genreLabel')}</label>
        <div class="c-filters__select-field">
          <ASelect id="books-genre" label={uiT(locale, 'allOption')} />
        </div>
      </div>
    </CustomColumn>
    <CustomColumn lg="4" md="4" sm="4">
      <div class="c-filters__select-wrap">
        <label for="books-publisher" class="c-filters__label">{uiT(locale, 'publisherLabel')}</label>
        <div class="c-filters__select-field">
          <ASelect id="books-publisher" label={uiT(locale, 'allOption')} />
        </div>
      </div>
    </CustomColumn>
  </CustomContainer>
</div>

<script>
  import { initBooksFilters } from '../../scripts/booksFilters';
  import { initCustomSelect }  from '../../scripts/customSelect';

  const initAll = () => {
    document.querySelectorAll<HTMLElement>('.c-filters').forEach(initBooksFilters);
    document.querySelectorAll<HTMLElement>('[data-select-id]').forEach(initCustomSelect);
  };

  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>