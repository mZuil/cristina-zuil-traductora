---
import { uiT } from "../../config/strings-ui";
import AButton from "../atoms/AButton.astro";
import AText from "../atoms/AText.astro";

const locale = Astro.currentLocale ?? "es";

const aboutMeUrl      = uiT(locale, "aboutMeUrl")      || "/sobre-mi";
const translationsUrl = uiT(locale, "translationsUrl") || "/traducciones";
const writingsUrl     = uiT(locale, "writingsUrl")     || "/escritos";
const articlesUrl     = uiT(locale, "articlesUrl")     || "/noticias";
---

<style lang="scss">
    @use "../../styles/mixins" as *;

    .c-model {
        position: relative;
        width: 100%;
        height: 100lvh;
        min-height: 240px;
        overflow: hidden;
        container-type: inline-size;

        &__canvas {
            width: 100%;
            height: 100%;
            display: block;
            touch-action: none;
        }

        &__tag {
            position: absolute;
            top: 50%;
            left: 50%;
            color: var(--color-blue-default);
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: opacity 0.1s ease, visibility 0.1s ease;

            &.is-visible {
                opacity: 1;
                visibility: visible;
                pointer-events: all;
            }

            &-button {
                padding: 5px 20px;
                text-align: center;
                border: 4px solid var(--color-blue-dark);
                border-radius: 50px;
                background-color: var(--color-white);
                pointer-events: auto;
                user-select: none;
                transition: background-color 0.2s ease;

                &:hover {
                    background-color: var(--color-blue-lightest);
                }
            }
        }
    }
</style>

<section class="c-model js-c-model" data-locale={Astro.currentLocale}>
    <canvas class="c-model__canvas js-c-model-canvas"></canvas>

    <div class="c-model__tag js-tag --about-me">
        <AButton as="a" href={aboutMeUrl} size="home-tags" class="c-model__tag-button">
            {uiT(Astro.currentLocale, "aboutMeTag")}
        </AButton>
    </div>
    <div class="c-model__tag js-tag --chick">
        <AText size="home-tags" class="c-model__tag-button">
            {uiT(Astro.currentLocale, "chickTag")}
        </AText>
    </div>
    <div class="c-model__tag js-tag --translations">
        <AButton as="a" href={translationsUrl} size="home-tags" class="c-model__tag-button">
            {uiT(Astro.currentLocale, "translationsTag")}
        </AButton>
    </div>
    <div class="c-model__tag js-tag --writings">
        <AButton as="a" href={writingsUrl} size="home-tags" class="c-model__tag-button">
            {uiT(Astro.currentLocale, "writingsTag")}
        </AButton>
    </div>
    <div class="c-model__tag js-tag --articles">
        <AButton as="a" href={articlesUrl} size="home-tags" class="c-model__tag-button">
            {uiT(Astro.currentLocale, "articlesTag")}
        </AButton>
    </div>
    <div class="c-model__tag js-tag --contact">
        <AButton as="a" href={"#contact"} size="home-tags" class="c-model__tag-button">
            {uiT(Astro.currentLocale, "contactTag")}
        </AButton>
    </div>
</section>

<script>
import { BaseComponent } from "../../helpers/base/BaseComponent";
import { uiT } from "../../config/strings-ui";

import * as THREE from "three";
import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";
import { DRACOLoader } from "three/examples/jsm/loaders/DRACOLoader.js";
import { RoomEnvironment } from "three/examples/jsm/environments/RoomEnvironment.js";
import { getPlatformModel } from "../../scripts/model-prefetch";

declare global {
    interface Window {
        openContactModal?: () => void;
    }
}

// ─── Tuning constants ──────────────────────────────────────────────────────────

const LERP_FACTOR      = 0.055;
const SCROLL_THRESHOLD = 30;
const SNAP_COOLDOWN_MS = 900;
const CAM_NEUTRAL      = new THREE.Vector3(70.4336, 13.7303, 0.0658);

// ─── Chick constants ───────────────────────────────────────────────────────────
const CHICK_SPEED        = 1.2;   // slower — more chick-like
const CHICK_ARRIVE_DIST  = 0.4;
const CHICK_EAT_DURATION = 1400;
const CHICK_TURN_SPEED   = 3.5;   // also slower — chickens pivot lazily
const CHICK_LOOKAHEAD    = 2.2;   // cast this far ahead for wall detection
const CHICK_PROBE_Y      = 0.2;   // low Y lift — catches low fences too

// ─── Snap-point definitions ───────────────────────────────────────────────────
interface SnapPoint {
    tagSelector: string;
    camPosition: THREE.Vector3;
}

const SNAP_POINTS: SnapPoint[] = [
    { tagSelector: "--about-me",     camPosition: new THREE.Vector3( 53.9117,  6.2968,  -0.0973) },
    { tagSelector: "--translations", camPosition: new THREE.Vector3( 49.2224, 18.3008,  58.9907) },
    { tagSelector: "--chick",        camPosition: new THREE.Vector3(-32.4472,  8.2288,  37.2811) },
    { tagSelector: "--contact",      camPosition: new THREE.Vector3(-57.8206,  7.2626,   0.0514) },
    { tagSelector: "--articles",     camPosition: new THREE.Vector3(-49.1818, 14.9362, -48.3925) },
    { tagSelector: "--writings",     camPosition: new THREE.Vector3( 38.3481, 21.9753, -56.5325) },
];

// ─── Hover animation config ───────────────────────────────────────────────────

interface HoverAnimConfig {
    name: string;
    mode: "loop-with-pause" | "speed-up" | "play-once" | "toggle-with-idle";
    pauseMs?: number;
    speedScale?: number;
    idleName?: string;
}

// ─── Component ────────────────────────────────────────────────────────────────

class CModel extends BaseComponent {
    canvas: HTMLCanvasElement | null;
    renderer: any;
    scene: any;
    camera: any;
    sizes: { width: number; height: number };
    model: any;
    raycaster: any;
    pointerNdc: any;
    clickableRoots: Map<any, string>;
    contactRoots: Set<any>;
    onPointerMove: ((e: PointerEvent) => void) | null;
    onPointerDown: ((e: PointerEvent) => void) | null;
    onPointerUp:   ((e: PointerEvent) => void) | null;
    pointerDownPos: { x: number; y: number } | null;
    frameId: number | null;
    ro: ResizeObserver | null;
    destroyed: boolean;
    tagsPositions: Array<{ position: THREE.Vector3; element: HTMLElement | null }>;
    mixer: THREE.AnimationMixer | null;
    animations: Array<{ name: string; action: THREE.AnimationAction }>;

    // ── Snap state ────────────────────────────────────────────────────────
    private snapIndex: number    = -1;
    private lastSnapTime: number = 0;
    private touchStartY: number  = 0;

    // ── Animated camera ───────────────────────────────────────────────────
    private currentCamPos: THREE.Vector3 = CAM_NEUTRAL.clone();
    private targetCamPos:  THREE.Vector3 = CAM_NEUTRAL.clone();
    private currentLookAt: THREE.Vector3 = new THREE.Vector3(0, 0, 0);
    private targetLookAt:  THREE.Vector3 = new THREE.Vector3(0, 0, 0);

    // ── Input handler refs for cleanup ────────────────────────────────────
    private onWheel:      ((e: WheelEvent) => void) | null = null;
    private onTouchStart: ((e: TouchEvent) => void) | null = null;
    private onTouchEnd:   ((e: TouchEvent) => void) | null = null;

    private frameCount: number = 0;
    private previousTime: number | null = null;

    // ── Raycasting ────────────────────────────────────────────────────────
    private interactiveMeshes: THREE.Object3D[] = [];
    private proxyMeshes: THREE.Mesh[] = [];

    // ── Hover animations ──────────────────────────────────────────────────
    private hoveredRoot: THREE.Object3D | null = null;
    private hoverAnimationMap: Map<any, HoverAnimConfig> = new Map();
    private hoverLoopTimeout: ReturnType<typeof setTimeout> | null = null;

    // ── Chick state ───────────────────────────────────────────────────────
    private chickAnimal:       THREE.Object3D | null = null;
    private chickClickRoot:  THREE.Object3D | null = null;  // for click detection
    private chickIsEating:   boolean = false;
    private chickEatUntil:   number = 0;
    private chickTarget:     THREE.Vector3 = new THREE.Vector3();
    private chickPauseUntil: number = 0;     // performance.now() timestamp
    private chickEatTimeout: ReturnType<typeof setTimeout> | null = null;
    private farmMeshes: THREE.Object3D[] = [];  // add this to class fields at the top
    private farmFrontMeshes: THREE.Object3D[] = [];
    private chickDir: THREE.Vector3 = new THREE.Vector3(1, 0, 0); // XZ heading, Y unused
    private farmBox: THREE.Box3 | null = null;

    constructor(nodeInDOM: HTMLElement) {
        super(nodeInDOM);

        this.canvas         = this.nodeInDOM.querySelector<HTMLCanvasElement>(".js-c-model-canvas");
        this.renderer       = null;
        this.scene          = null;
        this.camera         = null;
        this.sizes          = { width: 0, height: 0 };
        this.model          = null;
        this.raycaster      = null;
        this.pointerNdc     = null;
        this.clickableRoots = new Map();
        this.contactRoots   = new Set();
        this.onPointerMove  = null;
        this.onPointerDown  = null;
        this.onPointerUp    = null;
        this.pointerDownPos = null;
        this.frameId        = null;
        this.ro             = null;
        this.destroyed      = false;
        this.tagsPositions  = [];
        this.mixer          = null;
        this.animations     = [];
        this.farmMeshes     = [];
        this.farmFrontMeshes = [];

        this.init();
        document.addEventListener("astro:before-swap", this.destroy);
    }

    // ─── init ──────────────────────────────────────────────────────────────
    init = async (): Promise<void> => {
        if (!this.canvas) return;
        if (this.nodeInDOM.dataset.modelInit === "1") return;
        this.nodeInDOM.dataset.modelInit = "1";

        this.sizes = {
            width:  this.canvas.clientWidth,
            height: this.canvas.clientHeight,
        };

        /* RENDERER */
        this.renderer = new THREE.WebGLRenderer({
            canvas: this.canvas,
            antialias: true,
            alpha: true,
            powerPreference: "high-performance",
        });
        this.renderer.setPixelRatio(Math.min(2, window.devicePixelRatio || 1));
        this.renderer.outputColorSpace   = THREE.SRGBColorSpace;
        this.renderer.toneMapping        = THREE.ACESFilmicToneMapping;
        this.renderer.toneMappingExposure = 0.9;

        /* SCENE */
        this.scene = new THREE.Scene();

        /* CAMERA */
        this.camera = new THREE.PerspectiveCamera(55, 1, 0.1, 130);
        this.camera.position.copy(CAM_NEUTRAL);
        this.camera.lookAt(0, 0, 0);

        /* ENVIRONMENT + LIGHTS */
        const pmremGenerator = new THREE.PMREMGenerator(this.renderer);
        this.scene.environment = pmremGenerator.fromScene(new RoomEnvironment(), 0.04).texture;
        pmremGenerator.dispose();

        const ambient = new THREE.AmbientLight(0xffffff, 0.35);
        const key     = new THREE.DirectionalLight(0xffffff, 2.0);
        key.position.set(2, 3, 4);
        this.scene.add(ambient, key);

        /* TAG WORLD POSITIONS */
        this.tagsPositions = [
            { position: new THREE.Vector3( 39.0059,  8.1606,  -0.0007), element: this.nodeInDOM.querySelector(".js-tag.--about-me")     },
            { position: new THREE.Vector3( 28.8355, 20.5247,   8.7885), element: this.nodeInDOM.querySelector(".js-tag.--translations")  },
            { position: new THREE.Vector3( 19.6588, 23.2543, -27.0160), element: this.nodeInDOM.querySelector(".js-tag.--writings")      },
            { position: new THREE.Vector3(-23.3633, 19.9472, -22.8574), element: this.nodeInDOM.querySelector(".js-tag.--articles")      },
            { position: new THREE.Vector3(-40.6911,  8.2630,  -0.0034), element: this.nodeInDOM.querySelector(".js-tag.--contact")       },
            { position: new THREE.Vector3(-19.6904,  6.8916,  21.8700), element: this.nodeInDOM.querySelector(".js-tag.--chick")         },
        ];

        /* MODEL */
        const dracoLoader = new DRACOLoader();
        dracoLoader.setDecoderPath("/draco/");
        const loader = new GLTFLoader();
        loader.setDRACOLoader(dracoLoader);

        const gltf = await getPlatformModel();
        this.model = gltf.scene;
        this.scene.add(this.model);

        console.log(gltf.animations);

        /* ANIMATIONS */
        this.mixer = new THREE.AnimationMixer(this.model);

        console.log(gltf);

        this.animations = [
            { name: "awkningBookShop", action: this.mixer.clipAction(gltf.animations[0])  },
            { name: "chickWalking",    action: this.mixer.clipAction(gltf.animations[1])  },
            { name: "chickEating",     action: this.mixer.clipAction(gltf.animations[2])  },
            { name: "awkningKiosk",    action: this.mixer.clipAction(gltf.animations[3])  },
            { name: "mailbox",         action: this.mixer.clipAction(gltf.animations[4])  },
            { name: "bigTreeLeft",     action: this.mixer.clipAction(gltf.animations[5])  },
            { name: "bigTreeRight",    action: this.mixer.clipAction(gltf.animations[6])  },
            { name: "bigTreeLeft2",    action: this.mixer.clipAction(gltf.animations[7])  },
            { name: "rightTreeLeft",   action: this.mixer.clipAction(gltf.animations[8])  },
            { name: "rightTreeRight",  action: this.mixer.clipAction(gltf.animations[9])  },
            { name: "leftTreeLeft",    action: this.mixer.clipAction(gltf.animations[10]) },
            { name: "leftTreeRight",   action: this.mixer.clipAction(gltf.animations[11]) },
            { name: "crisDance",       action: this.mixer.clipAction(gltf.animations[12]) },
            { name: "crisIdle",        action: this.mixer.clipAction(gltf.animations[13]) },
            { name: "crisWave",        action: this.mixer.clipAction(gltf.animations[14]) },
        ];

        const getAction = (name: string) => this.animations.find(a => a.name === name)?.action;

        /* IDLE ANIMATIONS */
        const crisWave = getAction("crisWave");
        const crisIdle = getAction("crisIdle");

        if (crisWave && crisIdle) {
            crisWave.setLoop(THREE.LoopOnce, 1);
            crisWave.clampWhenFinished = true;
            crisWave.reset().play();

            const onWaveDone = (e: any) => {
                if (e.action !== crisWave) return;
                this.mixer!.removeEventListener("finished", onWaveDone);
                crisIdle.reset().play();
            };
            this.mixer.addEventListener("finished", onWaveDone);
        } else {
            crisIdle?.play();
        }
        getAction("awkningBookShop")?.play();
        getAction("awkningKiosk")?.play();
        getAction("chickWalking")?.play();   // start walking immediately

        /* RAYCASTER */
        this.raycaster  = new THREE.Raycaster();
        this.pointerNdc = new THREE.Vector2();

        /* CLICKABLE / CONTACT MESH ROOTS */
        const locale   = this.nodeInDOM.dataset.locale || "es";
        const children = this.model.children;

        const aboutMeLink      = children.find((c: any) => c.name === "cris");
        const translationsLink = children.find((c: any) => c.name === "book_shop");
        const tree1            = children.find((c: any) => c.name === "armature_big_tree");
        const tree2            = children.find((c: any) => c.name === "armature_right_tree");
        const tree3            = children.find((c: any) => c.name === "armature_left_tree");
        const newsLink         = children.find((c: any) => c.name === "kiosk");
        const contactButton    = children.find((c: any) => c.name === "Mailbox");
        const farm             = children.find((c: any) => c.name === "farm");
        const farmBounds       = children.find((c: any) => c.name === "Farm_Bounds");
        const chickAnimal      = children.find((c: any) => c.name === "chick");

        //For deleting visually the front part of the farm
        const frontNames = new Set(["Cylinder008", "Cylinder008_1", "Cylinder008_2", "Cylinder008_3"]);
        farm?.traverse((obj: any) => {
            if (obj instanceof THREE.Mesh && frontNames.has(obj.name)) {
                this.farmFrontMeshes.push(obj);
            }
        });

        if (farmBounds) {
            farmBounds.traverse((obj: any) => {
                if (obj instanceof THREE.Mesh) this.farmMeshes.push(obj);
            });
        }

        if (farmBounds) {
            this.farmBox = new THREE.Box3().setFromObject(farmBounds);
        }

        const aboutMeUrl      = uiT(locale as any, "aboutMeUrl")      || "/sobre-mi";
        const translationsUrl = uiT(locale as any, "translationsUrl") || "/traducciones";
        const writingsUrl     = uiT(locale as any, "writingsUrl")     || "/escritos";
        const articlesUrl     = uiT(locale as any, "articlesUrl")     || "/noticias";

        const reg  = (root: any, href: string) => { if (root) this.clickableRoots.set(root, href); };
        const regC = (root: any)               => { if (root) this.contactRoots.add(root); };

        reg(aboutMeLink,      aboutMeUrl);
        reg(translationsLink, translationsUrl);
        reg(tree1,            writingsUrl);
        reg(tree2,            writingsUrl);
        reg(tree3,            writingsUrl);
        reg(newsLink,         articlesUrl);
        regC(contactButton);
        // NOTE: chick is NOT added to clickableRoots — we handle it separately

        /* HOVER ANIMATION MAP */
        if (contactButton)    this.hoverAnimationMap.set(contactButton,    { name: "mailbox",         mode: "loop-with-pause", pauseMs: 1000 });
        if (aboutMeLink)      this.hoverAnimationMap.set(aboutMeLink,      { name: "crisDance",       mode: "toggle-with-idle", idleName: "crisIdle" });
        if (newsLink)         this.hoverAnimationMap.set(newsLink,         { name: "awkningKiosk",    mode: "speed-up", speedScale: 6        });
        if (translationsLink) this.hoverAnimationMap.set(translationsLink, { name: "awkningBookShop", mode: "speed-up", speedScale: 3        });

        /* BUILD INTERACTIVE MESHES */
        const heavyRoots       = new Set([aboutMeLink, contactButton]);
        const interactiveRoots = [...this.clickableRoots.keys(), ...this.contactRoots];

        interactiveRoots.forEach(root => {
            if (!root) return;

            if (heavyRoots.has(root)) {
                const proxy = this.buildProxy(root);
                if (this.clickableRoots.has(root)) {
                    this.clickableRoots.set(proxy, this.clickableRoots.get(root)!);
                }
                if (this.contactRoots.has(root)) {
                    this.contactRoots.add(proxy);
                }
                if (this.hoverAnimationMap.has(root)) {
                    this.hoverAnimationMap.set(proxy, this.hoverAnimationMap.get(root)!);
                }
                this.interactiveMeshes.push(proxy);
            } else {
                root.traverse((obj: any) => {
                    if (obj instanceof THREE.Mesh) this.interactiveMeshes.push(obj);
                });
            }
        });

        // ── NEW: register chick meshes for raycasting separately ───────────
        if (chickAnimal) {
            this.chickAnimal      = chickAnimal;
            this.chickClickRoot = chickAnimal;
            // Seed an initial walk target so the chick moves from frame 1
            this.pickNewChickTarget();

            chickAnimal.traverse((obj: any) => {
                if (obj instanceof THREE.Mesh) this.interactiveMeshes.push(obj);
            });
        }

        /* INPUT */
        this.setupScrollInput();
        this.setupPointerEvents();

        /* RESIZE */
        this.resize();
        this.ro = new ResizeObserver(() => this.resize());
        this.ro.observe(this.nodeInDOM);

        /* START */
        this.renderer.render(this.scene, this.camera);
        this.tick();

        this.nodeInDOM.dataset.modelReady = "1";
        this.nodeInDOM.dispatchEvent(new CustomEvent("model:ready", { bubbles: true }));
    };

    // ─── Proxy builder ─────────────────────────────────────────────────────
    private buildProxy(root: THREE.Object3D): THREE.Mesh {
        const box    = new THREE.Box3().setFromObject(root);
        const size   = new THREE.Vector3();
        const center = new THREE.Vector3();
        box.getSize(size);
        box.getCenter(center);

        const proxy = new THREE.Mesh(
            new THREE.BoxGeometry(size.x, size.y, size.z),
            new THREE.MeshBasicMaterial({ visible: false }),
        );
        proxy.position.copy(center);
        this.scene.add(proxy);
        this.proxyMeshes.push(proxy);
        return proxy;
    }

    // ─── Hover animation helpers ───────────────────────────────────────────
    private getHoverConfig(obj: any): HoverAnimConfig | null {
        let cur: any = obj;
        while (cur) {
            const config = this.hoverAnimationMap.get(cur);
            if (config) return config;
            cur = cur.parent;
        }
        return null;
    }

    private playHoverAnimation(config: HoverAnimConfig): void {
        const action = this.animations.find(a => a.name === config.name)?.action;
        if (!action) return;

        if (config.mode === "speed-up") {
            action.timeScale = config.speedScale ?? 2;
            return;
        }

        if (config.mode === "play-once") {
            action.setLoop(THREE.LoopOnce, 1);
            action.clampWhenFinished = true;
            action.reset().play();
            return;
        }

        if (config.mode === "loop-with-pause") {
            const scheduleNext = () => {
                action.reset().play();
                const onFinished = (e: any) => {
                    if (e.action !== action) return;
                    this.mixer!.removeEventListener("finished", onFinished);
                    if (this.hoveredRoot) {
                        this.hoverLoopTimeout = setTimeout(() => {
                            if (this.hoveredRoot) scheduleNext();
                        }, config.pauseMs ?? 1000);
                    }
                };
                this.mixer!.addEventListener("finished", onFinished);
            };
            action.setLoop(THREE.LoopOnce, 1);
            action.clampWhenFinished = false;
            scheduleNext();
        }

        if (config.mode === "toggle-with-idle") {
            const idleAction = config.idleName
                ? this.animations.find(a => a.name === config.idleName)?.action
                : null;

            idleAction?.stop();

            action.setLoop(THREE.LoopRepeat, Infinity);
            action.clampWhenFinished = false;
            action.reset().play();
            return;
        }
    }

    private stopHoverAnimation(config: HoverAnimConfig): void {
        if (this.hoverLoopTimeout !== null) {
            clearTimeout(this.hoverLoopTimeout);
            this.hoverLoopTimeout = null;
        }

        const action = this.animations.find(a => a.name === config.name)?.action;
        if (!action) return;

        if (config.mode === "speed-up") {
            action.timeScale = 1;
            return;
        }

        if (config.mode === "toggle-with-idle") {
            action.stop();

            const idleAction = config.idleName
                ? this.animations.find(a => a.name === config.idleName)?.action
                : null;
            idleAction?.reset().play();
            return;
        }

        action.stop();
    }

    // ─── Chick helpers ─────────────────────────────────────────────────────

    /** Returns true if the given intersected object belongs to the chick root. */
    private isChick(obj: THREE.Object3D): boolean {
        if (!this.chickClickRoot) return false;
        let cur: any = obj;
        while (cur) {
            if (cur === this.chickClickRoot) return true;
            cur = cur.parent;
        }
        return false;
    }

    /** Pick a random XZ position inside FARM bounds as the next walk target. */
    private pickNewChickTarget(): void {
        const worldPos = new THREE.Vector3();
        if (this.chickAnimal) this.chickAnimal.getWorldPosition(worldPos);

        const WALK_DIST_MIN = 3;
        const WALK_DIST_MAX = 8;

        // Pick a direction within ±60° of the current heading
        // so the chick curves and meanders rather than spinning to face a random point
        const currentAngle = Math.atan2(this.chickDir.x, this.chickDir.z);
        const spread       = (Math.PI / 3);   // ±60°
        const angle        = currentAngle + (Math.random() - 0.5) * 2 * spread;
        const dist         = WALK_DIST_MIN + Math.random() * (WALK_DIST_MAX - WALK_DIST_MIN);

        let x = worldPos.x + Math.sin(angle) * dist;
        let z = worldPos.z + Math.cos(angle) * dist;

        // Clamp to farmBox so the picked target is always valid
        if (this.farmBox) {
            const pad = 1.0; // stay this far from the wall edge
            x = Math.max(this.farmBox.min.x + pad, Math.min(this.farmBox.max.x - pad, x));
            z = Math.max(this.farmBox.min.z + pad, Math.min(this.farmBox.max.z - pad, z));
        }

        this.chickTarget.set(x, worldPos.y, z);
    }

    /** Called when the user clicks the chick. Triggers eating for CHICK_EAT_DURATION ms. */
    private triggerChickEating(): void {
        if (this.chickIsEating) {
            // Re-click while eating: just reset the timer
            this.chickEatUntil = performance.now() + CHICK_EAT_DURATION;
            return;
        }

        this.chickIsEating = true;
        this.chickEatUntil = performance.now() + CHICK_EAT_DURATION;

        const walking = this.animations.find(a => a.name === "chickWalking")?.action;
        const eating  = this.animations.find(a => a.name === "chickEating")?.action;

        walking?.stop();

        if (eating) {
            eating.setLoop(THREE.LoopRepeat, Infinity);
            eating.reset().play();
        }

        // Schedule return to walking
        if (this.chickEatTimeout !== null) clearTimeout(this.chickEatTimeout);
        this.chickEatTimeout = setTimeout(() => {
            this.chickEatTimeout  = null;
            this.chickIsEating    = false;

            eating?.stop();
            walking?.reset().play();
            this.pickNewChickTarget();   // head somewhere new after eating
        }, CHICK_EAT_DURATION);
    }

    /**
     * Called every frame from tick().
     * Moves the chick toward its current target and rotates it to face the direction of travel.
     * Does nothing while the chick is eating or paused.
     */
    private updateChick(deltaTime: number): void {
        if (!this.chickAnimal || this.chickIsEating) return;

        const now = performance.now();
        if (now < this.chickPauseUntil) return;

        // ── World-space position ──────────────────────────────────────────────
        // chickAnimal.position is LOCAL — we need world space for the raycaster
        const worldPos = new THREE.Vector3();
        this.chickAnimal.getWorldPosition(worldPos);

        const target = this.chickTarget;
        const dx     = target.x - worldPos.x;
        const dz     = target.z - worldPos.z;
        const dist   = Math.sqrt(dx * dx + dz * dz);

        if (dist < CHICK_ARRIVE_DIST) {
            this.pickNewChickTarget();
            return;
        }

        // Desired direction toward target
        const desiredDirX = dx / dist;
        const desiredDirZ = dz / dist;

        // ── Smooth steering — blend current heading toward desired ────────────
        // This makes direction changes gradual rather than instant
        const STEER_SPEED = 2.5; // how fast the heading turns (rad/s equivalent)
        const steerAmount = Math.min(STEER_SPEED * deltaTime, 1.0);
        this.chickDir.x += (desiredDirX - this.chickDir.x) * steerAmount;
        this.chickDir.z += (desiredDirZ - this.chickDir.z) * steerAmount;

        // Re-normalise to prevent drift
        const dirLen = Math.sqrt(this.chickDir.x ** 2 + this.chickDir.z ** 2);
        if (dirLen < 0.001) return;
        const dirX = this.chickDir.x / dirLen;
        const dirZ = this.chickDir.z / dirLen;

        // ── Wall collision in world space ─────────────────────────────────────
        let wallAhead = false;
        if (this.farmMeshes.length > 0) {
            const savedFar = this.raycaster.far;
            const origin   = new THREE.Vector3(worldPos.x, worldPos.y + CHICK_PROBE_Y, worldPos.z);
            const dir      = new THREE.Vector3(dirX, 0, dirZ);
            this.raycaster.set(origin, dir);
            this.raycaster.far = CHICK_LOOKAHEAD;

            wallAhead = this.raycaster.intersectObjects(this.farmMeshes, true).length > 0;
            this.raycaster.far = savedFar;
        }

        if (wallAhead) {
            // Rotate heading ~180° ± random spread and pick a new target inward
            const randomAngle = (Math.random() - 0.5) * Math.PI * 0.75;
            const cos = Math.cos(Math.PI + randomAngle);
            const sin = Math.sin(Math.PI + randomAngle);
            this.chickDir.x = dirX * cos - dirZ * sin;
            this.chickDir.z = dirX * sin + dirZ * cos;

            const STEP_AWAY = 5;
            this.chickTarget.set(
                worldPos.x + this.chickDir.x * STEP_AWAY,
                worldPos.y,
                worldPos.z + this.chickDir.z * STEP_AWAY,
            );
            return;
        }

        // ── Move (in local space — undo parent transform for position delta) ──
        // Since we move in world XZ, and the chick's parent may have a transform,
        // we apply the delta directly to local position using the world direction.
        // For a flat scene (no parent rotation/scale), world delta == local delta.
        const step = CHICK_SPEED * deltaTime;
        this.chickAnimal.position.x += dirX * step;
        this.chickAnimal.position.z += dirZ * step;

        // ── Natural rotation — face the actual movement direction smoothly ─────
        // We rotate the model to face dirX/dirZ, but only nudge it each frame
        // so it visually "leans into" the turn rather than spinning in place
        const targetAngle  = Math.atan2(dirX, dirZ);
        const currentAngle = this.chickAnimal.rotation.y;

        // Shortest-path delta
        let angleDelta = targetAngle - currentAngle;
        while (angleDelta >  Math.PI) angleDelta -= Math.PI * 2;
        while (angleDelta < -Math.PI) angleDelta += Math.PI * 2;

        // Ease toward target angle — faster when the turn is sharp
        const turnEase = Math.min(Math.abs(angleDelta) / (Math.PI * 0.5), 1.0); // 0–1
        const effectiveTurnSpeed = CHICK_TURN_SPEED * (0.4 + 0.6 * turnEase);   // slower on small corrections
        this.chickAnimal.rotation.y += Math.sign(angleDelta) * Math.min(Math.abs(angleDelta), effectiveTurnSpeed * deltaTime);
    }

    // ─── Scroll snap input ─────────────────────────────────────────────────
    private setupScrollInput(): void {
        if (!this.canvas) return;

        this.onWheel = (e: WheelEvent) => {
            e.preventDefault();
            e.stopPropagation();
            const delta = Math.abs(e.deltaY) >= Math.abs(e.deltaX) ? e.deltaY : e.deltaX;
            if (Math.abs(delta) < SCROLL_THRESHOLD) return;
            this.advanceSnap(delta > 0 ? 1 : -1);
        };

        this.onTouchStart = (e: TouchEvent) => {
            this.touchStartY = e.touches[0].clientY;
        };

        this.onTouchEnd = (e: TouchEvent) => {
            const dy = this.touchStartY - e.changedTouches[0].clientY;
            if (Math.abs(dy) < SCROLL_THRESHOLD) return;
            this.advanceSnap(dy > 0 ? 1 : -1);
        };

        this.canvas.addEventListener("wheel",      this.onWheel,      { passive: false });
        this.canvas.addEventListener("touchstart", this.onTouchStart, { passive: true  });
        this.canvas.addEventListener("touchend",   this.onTouchEnd,   { passive: true  });
    }

    private advanceSnap(dir: 1 | -1): void {
        const now = performance.now();
        if (now - this.lastSnapTime < SNAP_COOLDOWN_MS) return;
        this.lastSnapTime = now;

        const count = SNAP_POINTS.length;
        const next  = ((this.snapIndex + dir) % count + count) % count;
        this.goToSnap(next);
    }

    private goToSnap(index: number): void {
        this.snapIndex = index;
        this.targetCamPos.copy(SNAP_POINTS[index].camPosition);
        this.targetLookAt.set(0, 0, 0);

        const isChickSnap = SNAP_POINTS[index].tagSelector === "--chick";
        this.farmFrontMeshes.forEach(m => { (m as any).visible = !isChickSnap; });
    }

    // ─── Pointer events ────────────────────────────────────────────────────
    private setupPointerEvents(): void {
        if (!this.canvas) return;

        const updateNdc = (e: PointerEvent) => {
            const rect = this.canvas!.getBoundingClientRect();
            const x = (e.clientX - rect.left) / Math.max(1, rect.width);
            const y = (e.clientY - rect.top)  / Math.max(1, rect.height);
            this.pointerNdc.set(x * 2 - 1, -(y * 2 - 1));
        };

        const findClickable = (obj: any): string | null => {
            let cur: any = obj;
            while (cur) {
                const href = this.clickableRoots.get(cur);
                if (href) return href;
                cur = cur.parent;
            }
            return null;
        };

        const findContact = (obj: any): boolean => {
            let cur: any = obj;
            while (cur) { if (this.contactRoots.has(cur)) return true; cur = cur.parent; }
            return false;
        };

        // ── NEW: chick-aware raycast result ───────────────────────────────
        const raycast = (): { isContact: boolean; isChick: boolean; href?: string; root?: any } | null => {
            if (!this.raycaster || !this.camera || !this.model) return null;
            this.raycaster.setFromCamera(this.pointerNdc, this.camera);
            const hits = this.raycaster.intersectObjects(this.interactiveMeshes, false);
            if (!hits.length) return null;
            const obj  = hits[0].object;

            // Check chick first (highest priority for click)
            if (this.isChick(obj)) return { isContact: false, isChick: true, root: obj };

            const href = findClickable(obj);
            if (href) return { isContact: false, isChick: false, href, root: obj };
            if (findContact(obj)) return { isContact: true, isChick: false, root: obj };
            return null;
        };

        this.onPointerMove = (e: PointerEvent) => {
            updateNdc(e);
            const hit = raycast();
            this.canvas!.style.cursor = hit ? "pointer" : "default";

            const newRoot = hit?.root ?? null;
            if (newRoot === this.hoveredRoot) return;

            if (this.hoveredRoot) {
                const prevConfig = this.getHoverConfig(this.hoveredRoot);
                if (prevConfig) this.stopHoverAnimation(prevConfig);
                this.hoveredRoot = null;
            }

            if (newRoot) {
                this.hoveredRoot = newRoot;
                const nextConfig = this.getHoverConfig(newRoot);
                if (nextConfig) this.playHoverAnimation(nextConfig);
            }
        };

        this.onPointerDown = (e: PointerEvent) => {
            this.pointerDownPos = { x: e.clientX, y: e.clientY };
        };

        this.onPointerUp = (e: PointerEvent) => {
            const start = this.pointerDownPos;
            this.pointerDownPos = null;
            if (!start) return;
            if (Math.hypot(e.clientX - start.x, e.clientY - start.y) > 6) return;
            updateNdc(e);
            const hit = raycast();
            if (!hit) return;

            // ── NEW: chick click ───────────────────────────────────────────
            if (hit.isChick) {
                this.triggerChickEating();
                return;
            }

            if (hit.isContact) { window.openContactModal?.(); return; }
            import("astro:transitions/client")
                .then(({ navigate }) => navigate(hit.href!))
                .catch(() => { window.location.href = hit.href!; });
        };

        this.canvas.addEventListener("pointermove", this.onPointerMove);
        this.canvas.addEventListener("pointerdown", this.onPointerDown);
        this.canvas.addEventListener("pointerup",   this.onPointerUp);
    }

    // ─── resize ────────────────────────────────────────────────────────────
    resize = (): void => {
        if (!this.renderer || !this.camera) return;
        const rect   = this.nodeInDOM.getBoundingClientRect();
        const width  = Math.max(1, Math.floor(rect.width));
        const height = Math.max(1, Math.floor(rect.height));
        this.sizes   = { width: window.innerWidth, height: window.innerHeight };
        this.renderer.setSize(width, height, false);
        this.camera.aspect = width / height;
        this.camera.updateProjectionMatrix();
    };

    // ─── tick ──────────────────────────────────────────────────────────────
    tick = (): void => {
        if (!this.renderer || !this.scene || !this.camera) return;

        const nowMs     = performance.now();
        const deltaTime = this.previousTime == null ? 0 : (nowMs - this.previousTime) / 1000;
        this.previousTime = nowMs;

        // 1. Lerp camera
        this.currentCamPos.lerp(this.targetCamPos, LERP_FACTOR);
        this.currentLookAt.lerp(this.targetLookAt, LERP_FACTOR);
        this.camera.position.copy(this.currentCamPos);
        this.camera.lookAt(this.currentLookAt);

        // 2. Update tag screen positions
        this.frameCount++;
        const checkOcclusion = this.frameCount % 6 === 0;

        for (const tag of this.tagsPositions) {
            if (!tag.element) continue;

            const screenPos = tag.position.clone();
            screenPos.project(this.camera);

            if (checkOcclusion) {
                this.raycaster.setFromCamera(
                    new THREE.Vector2(screenPos.x, screenPos.y),
                    this.camera,
                );
                const intersects  = this.raycaster.intersectObjects(this.scene.children, true);
                const tagDistance = tag.position.distanceTo(this.camera.position);

                if (intersects.length === 0) {
                    tag.element.classList.toggle("is-visible", tagDistance <= 59);
                } else {
                    tag.element.classList.toggle("is-visible", intersects[0].distance >= tagDistance);
                }
            }

            const tx = screenPos.x *  this.sizes.width  * 0.5;
            const ty = screenPos.y * -this.sizes.height  * 0.5;
            tag.element.style.transform = `translate(calc(-50% + ${tx}px), calc(-50% + ${ty}px))`;
        }

        // 3. Update animations
        this.mixer?.update(deltaTime);

        // 4. ── NEW: update chick movement ─────────────────────────────────
        this.updateChick(deltaTime);

        // 5. Render
        this.renderer.render(this.scene, this.camera);
        this.frameId = requestAnimationFrame(this.tick);
    };

    // ─── destroy ───────────────────────────────────────────────────────────
    destroy = (): void => {
        if (this.destroyed) return;
        this.destroyed = true;

        if (this.frameId != null) { cancelAnimationFrame(this.frameId); this.frameId = null; }

        this.ro?.disconnect();
        this.ro = null;

        if (this.hoverLoopTimeout !== null) {
            clearTimeout(this.hoverLoopTimeout);
            this.hoverLoopTimeout = null;
        }

        // ── NEW: clear chick timeout ───────────────────────────────────────
        if (this.chickEatTimeout !== null) {
            clearTimeout(this.chickEatTimeout);
            this.chickEatTimeout = null;
        }

        if (this.canvas) {
            if (this.onWheel)       this.canvas.removeEventListener("wheel",       this.onWheel);
            if (this.onTouchStart)  this.canvas.removeEventListener("touchstart",  this.onTouchStart);
            if (this.onTouchEnd)    this.canvas.removeEventListener("touchend",    this.onTouchEnd);
            if (this.onPointerMove) this.canvas.removeEventListener("pointermove", this.onPointerMove);
            if (this.onPointerDown) this.canvas.removeEventListener("pointerdown", this.onPointerDown);
            if (this.onPointerUp)   this.canvas.removeEventListener("pointerup",   this.onPointerUp);
        }

        this.onWheel        = null;
        this.onTouchStart   = null;
        this.onTouchEnd     = null;
        this.onPointerMove  = null;
        this.onPointerDown  = null;
        this.onPointerUp    = null;
        this.pointerDownPos = null;
        this.clickableRoots.clear();
        this.contactRoots.clear();
        this.hoverAnimationMap.clear();
        this.hoveredRoot = null;

        // ── NEW: clear chick refs ──────────────────────────────────────────
        this.chickAnimal      = null;
        this.chickClickRoot = null;

        this.proxyMeshes.forEach(p => {
            p.geometry.dispose();
            (p.material as THREE.Material).dispose();
            this.scene?.remove(p);
        });
        this.proxyMeshes       = [];
        this.interactiveMeshes = [];

        if (this.scene) {
            this.scene.traverse((obj: any) => {
                if (obj instanceof THREE.Mesh) {
                    obj.geometry.dispose();
                    const mats = Array.isArray(obj.material) ? obj.material : [obj.material];
                    mats.forEach((m: any) => m.dispose());
                }
            });
        }

        this.renderer?.dispose();
        this.renderer?.forceContextLoss();
        this.renderer = null;
        this.scene    = null;
        this.camera   = null;
        this.model    = null;

        document.removeEventListener("astro:before-swap", this.destroy);
    };
}

function initModel() {
    BaseComponent.mountAll(".js-c-model", CModel);
}

document.addEventListener("astro:page-load", initModel);
</script>