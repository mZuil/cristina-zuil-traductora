---
import CustomColumn from '../../helpers/structure/CustomColumn/CustomColumn.astro';
import CustomContainer from '../../helpers/structure/CustomContainer/CustomContainer.astro';

// ── Helpers shared between SSR and client ──────────────────────────────────
// (duplicated here because Astro frontmatter runs server-side only;
//  the client version lives in booksList.ts)

const SPINE_PALETTE = [
  '#6B3A2A', '#1A3D30', '#5C3D2A', '#5E1E1E',
  '#1B2535', '#7A2E10', '#3B2E5E', '#1A3D27',
];

function hashColor(str: string): string {
  let h = 0;
  for (let i = 0; i < str.length; i++) h = (h * 31 + str.charCodeAt(i)) >>> 0;
  return SPINE_PALETTE[h % SPINE_PALETTE.length];
}

// Strapi URL is only used to build image src — API calls go through /api/*
const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL ?? '';

// ── Props ──────────────────────────────────────────────────────────────────
interface Props {
  locale?: string;
  bookCategory: 'traduccion' | 'escrito';
  initialItems: any[];
  initialTotal: number;
  pageSize?: number;
}

const {
  locale       = 'es',
  bookCategory,
  pageSize     = 12,
} = Astro.props;

const labels = {
  genre:     locale === 'en' ? 'Genre'     : 'Género',
  publisher: locale === 'en' ? 'Publisher' : 'Editorial',
  year:      locale === 'en' ? 'Year'      : 'Año',
  empty:     locale === 'en' ? 'No results found.' : 'No hay resultados.',
  prev:      locale === 'en' ? 'Previous page'     : 'Página anterior',
  next:      locale === 'en' ? 'Next page'         : 'Página siguiente',
  results:   locale === 'en' ? 'books'             : 'libros',
  pagination:locale === 'en' ? 'Pagination'        : 'Paginación',
};
---

<style lang="scss">
  .c-books-list {
    position: relative;
    background-color: var(--color-white);
    z-index: 1;
    padding-block: 24px 60px; //TODO: change

    &__grid {
        display: grid;
        grid-template-columns: repeat(4, calc(var(--width-col) * 3 + var(--grid-gutter) * 2));
        column-gap: var(--grid-gutter);
        row-gap: 24px;
    }

    &__pagination {
        width: 100%;
        display: flex;
        justify-content: center;
        margin-top: 146px;
    }

    &__pages {
        display: flex;
        flex-direction: row;
        gap: 10px;
    }

    :global(.c-books-list__pagination-btn) {
        width: 50px;
        height: 50px;
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;

        background-color: transparent;
        border: none;
        cursor: pointer;
        
        text-align: center;
        padding-left: 3px;

        transition: color 0.2s ease-in-out;

        &::after {
            content: '';
            position: absolute;
            inset: 0;
            border: 2px solid var(--color-blue-default);
            border-radius: 50%;
            pointer-events: none;
            z-index: -1;
            transition: background-color 0.2s ease-in-out;
        }

        &.is-current {
            color: var(--color-white);
            pointer-events: none;

            &::after {
                background-color: var(--color-blue-default);
            }
        }
        
        &:hover {
            &::after {
                background-color: color-mix(in srgb, var(--color-blue-default) 20%, transparent);
            }
        }
    }
}
</style>

<section class="c-books-list" data-locale={locale} data-category={bookCategory} data-page-size={String(pageSize)} data-strapi-url={STRAPI_URL}>
  <CustomContainer>
    <CustomColumn lg="12" md="8" sm="4">
      <div class="c-books-list__grid"></div>

      <nav class="c-books-list__pagination" aria-label={labels.pagination}>
        <div class="c-books-list__pages" data-pages></div>
      </nav>
    </CustomColumn>
  </CustomContainer>
</section>

<script>
  import { initBooksList } from '../../scripts/booksList';

  const initAll = () => {
    document.querySelectorAll<HTMLElement>('.c-books-list').forEach((root) => {
      initBooksList(root);
    });
  };

  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>