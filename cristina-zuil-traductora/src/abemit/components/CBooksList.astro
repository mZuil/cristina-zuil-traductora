---
import CustomColumn from "../../helpers/structure/CustomColumn/CustomColumn.astro";
import CustomContainer from "../../helpers/structure/CustomContainer/CustomContainer.astro";
import { uiT } from "../../config/strings-ui";

// Strapi URL is only used to build image src — API calls go through /api/*
const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL ?? "";

// ── Props ──────────────────────────────────────────────────────────────────
interface Props {
  locale?: string;
  bookCategory: "traduccion" | "escrito";
  pageSize?: number;
}

const { locale = "es", bookCategory, pageSize = 12 } = Astro.props;
---

<style lang="scss">

  @use '../../styles/mixins.scss' as *;
  
  .c-books-list {

    $self: &;

    position: relative;
    background-color: var(--color-white);
    z-index: 1;
    padding-block: 100px 60px;

    &__grid {
      display: grid;
      grid-template-columns: repeat(4, calc(var(--width-col) * 3 + var(--grid-gutter) * 2));
      column-gap: var(--grid-gutter);
      row-gap: 24px;
    }

    /* Book item */
    :global(.c-books-list__book-container) {
      position: relative;
      perspective: 1200px;
      cursor: pointer;
      aspect-ratio: 2/3;
      transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    :global(.c-books-list__book-container:hover .c-books-list__book-cover) {
      transform: rotateY(-23deg);
    }

    :global(.c-books-list__book-container.is-open .c-books-list__book-cover) {
      transform: rotateY(-83deg);
    }

    :global(.c-books-list__book-scene) {
      width: 100%;
      height: 100%;
      position: relative;
      transform-style: preserve-3d;
    }

    :global(.c-books-list__book-cover) {
      position: absolute;
      inset: 0;
      border-radius: 0 20px 20px 0;
      transform-origin: left center;
      overflow: hidden;
      pointer-events: none;
      will-change: transform;
      transition: transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
      z-index: 2;

      :global(picture) {
        width: 100%;
        height: 100%;
        display: block;
      }

      :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center center;
        display: block;

        transition: filter 0.25s ease, transform 0.25s ease;
      }

      :global(img.is-lqip) {
        filter: blur(12px);
        transform: scale(1.02);
      }
    }

    :global(.c-books-list__book-page) {
        width: 100%;
        height: 100%;
        position:absolute;
        top:0;
        right:0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 13px;
        padding-inline: 50px;
        background:#fffef9;
        border: 1px solid var(--color-grey);
        border-radius: 0 20px 20px 0;
        overflow:hidden;
    }

    //Lines of the pages
    :global(.c-books-list__book-page::before) {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(transparent, transparent 26px, rgba(13, 27, 42, .04) 26px, rgba(13, 27, 42, .04) 27px);
      pointer-events: none;
    }

    :global(.c-books-list__book-section) {
      display: flex;
      flex-direction: column;
      gap: 8px;
      color: var(--color-blue-dark);
      pointer-events: none;
    }
    
    :global(.c-books-list__heading-field) {
      @include use-font("caption");
    }

    :global(.c-books-list__value-field) {
      @include use-font("small-text");
      font-weight: 700;

      &.--genres {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }
    }

    :global(.c-books-list__genre) {
      width: fit-content;
      display: inline-block;
      padding: 4px 8px;
      border-radius: 20px;
      background-color: var(--color-blue-light);
      color: var(--color-blue-dark);
      font-weight: 700;
    }

    :global(.c-books-list__divider) {
      margin-block: 5px;
    }

    :global(.c-books-list__book-title) {
      @include use-font("small-text");

      font-weight: 700;
      padding-bottom: 3px;
    }

    :global(.c-books-list__book-author) {
      @include use-font("small-text");
    }

    :global(.c-books-list__button) {
      @include use-font("small-text");

      margin-top: 20px;
      padding: 6px 8px;
      color: var(--color-white);
      background-color: var(--color-blue-default);
      border-radius: 20px;
      text-decoration: none;
      text-align: center;
      font-weight: 700 !important;
      transition: background-color 0.2s ease-in-out;
      pointer-events: none;

      &:hover {
        background-color: var(--color-blue-dark);
      }
    }

    :global(.c-books-list__book-container.is-open .c-books-list__button) {
      pointer-events: auto;
    }

    :global(.c-books-list__empty) {
      @include use-font("subheading-1");

      width: 100%;
      position: absolute;
      top: 40%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
    }

    /* Pagination */
    &__pagination {
      width: 100%;
      display: flex;
      justify-content: center;
      margin-top: 111px;
    }

    &__pages {
      display: flex;
      flex-direction: row;
      gap: 10px;
    }

    :global(.c-books-list__pagination-btn) {
      width: 50px;
      height: 50px;
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;

      background-color: transparent;
      border: none;
      cursor: pointer;

      text-align: center;

      transition: color 0.2s ease-in-out;

      &::after {
        content: "";
        position: absolute;
        inset: 0;
        border: 2px solid var(--color-blue-default);
        border-radius: 50%;
        pointer-events: none;
        z-index: -1;
        transition: background-color 0.2s ease-in-out;
      }

      &.is-current {
        color: var(--color-white);
        pointer-events: none;

        &::after {
          background-color: var(--color-blue-default);
        }
      }

      &:hover {
        &::after {
          background-color: color-mix(in srgb, var(--color-blue-default) 20%, transparent);
        }
      }
    }
  }
</style>

<section class="c-books-list" data-locale={locale} data-category={bookCategory} data-page-size={String(pageSize)} data-strapi-url={STRAPI_URL}>
  <CustomContainer>
    <CustomColumn lg="12" md="8" sm="4">
      <div class="c-books-list__grid"></div>

      <nav class="c-books-list__pagination" aria-label={uiT(locale, "pagination")}>
        <div class="c-books-list__pages" data-pages></div>
      </nav>
    </CustomColumn>
  </CustomContainer>
</section>

<script>
  import { initBooksList } from "../../scripts/booksList";

  const initAll = () => {
    document.querySelectorAll<HTMLElement>(".c-books-list").forEach((root) => {
      initBooksList(root);
    });
  };
  document.addEventListener("astro:page-load", initAll);
</script>
