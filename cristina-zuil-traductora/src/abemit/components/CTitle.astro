---
import CustomContainer from "../../helpers/structure/CustomContainer/CustomContainer.astro";
import CustomColumn from "../../helpers/structure/CustomColumn/CustomColumn.astro";
import AText from "../atoms/AText.astro";
import type { Text } from "../../helpers/interfaces/Text.astro";
import type { StrapiImage } from "../../helpers/interfaces/StrapiImage";
import AImage from "../atoms/AImage.astro";

interface Props {
    title: string;
    hasPoem: boolean;
    poemStanzas?: Text[];
    images?: StrapiImage[];
}

const { title, hasPoem, poemStanzas, images } = Astro.props;

let titleText = "";

if (!title) {
    throw new Error("Title is required");
} else {
    const titleParts = title.split(" ");
    titleText = `
        <span class="c-title__text-part --first" aria-hidden="true">${titleParts[0]}</span>
        <br aria-hidden="true">
        <span class="c-title__text-part --second" aria-hidden="true">${titleParts.slice(1).join(" ")}</span>
    `;
}
---

<style lang="scss">
    @use "../../styles/mixins" as *;

    .c-title {
        @include use-font(menu-item);

        position: relative;
        overflow: clip;
        background-color: var(--color-blue-light);
        z-index: 0;

        &.is-frozen {
            position: fixed;
            left: 0;
            right: 0;
            z-index: 0;

            &.--aling-top {
                top: 0;
            }

            &.--aling-bottom {
                bottom: 0;
            }
        }

        &__background {
            position: absolute;
            top: 7px;
            left: 0;
            right: 0;
            bottom: 0;
            overflow: hidden;

            &-svg {
                width: 100%;
            }
        }

        &__text {
            position: relative;
            padding-block: 215px 145px;
            text-align: center;

            :global(.c-title__text-part.--first) {
                color: var(--color-blue-dark);
            }

            :global(.c-title__text-part.--second) {
                color: var(--color-blue-default);
            }
        }

        // POEM
        &__poem {
            position: relative;
            height: 100dvh;
        }

        &__poem-wrapper {
            height: 100dvh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: absolute;
            inset: 0;
        }

        &__stanza-wrapper {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;

            &.is-active {
                pointer-events: auto;
            }
        }

        &__poem-line {
            text-align: center;
        }

        // IMAGES
        &__poem-image {
            position: absolute;
            top: calc(50% - 125px); // half of height, avoids transform conflict with GSAP
            width: 200px;
            height: 250px;
            object-fit: cover;
            pointer-events: none;
            left: 0;
        }
    }
</style>

<section class="c-title js-c-title">
    <div class="c-title__blue-container">
        <div class="c-title__background">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 1440 294" class="c-title__background-svg">
                <g fill="#fff" opacity=".22">
                    <path d="M-76 122.191c0-22.091 17.909-40 40-40h210.278v43.663c0 22.091-17.908 40-40 40H-36c-22.091 0-40-17.909-40-40z"></path>
                    <path d="M114.722 106.652c0-13.51 10.951-24.46 24.461-24.46h201.356c13.51 0 24.461 10.95 24.461 24.46 0 13.509-10.951 24.461-24.461 24.461H139.183c-13.51 0-24.461-10.952-24.461-24.461"></path>
                    <path d="M49.494 52c0-22.091 17.908-40 40-40h156.098c22.091 0 40 17.909 40 40v37.99H49.494z"></path>
                    <path d="M49.848 63.757c-2.661 12.692-7.974 16.714-23.752 18.789h23.752z"></path>
                    <path d="M168 150c2.913-14.185 8.729-18.68 26-21h-26z"></path>
                    <path d="M304.026 84.319c-12.692-2.662-16.714-7.975-18.789-23.752v23.752z"></path>
                </g>
                <g fill="#fff" opacity=".2">
                    <path d="M148.931 223.159c1.71 8.152 5.123 10.736 15.257 12.069h-15.257z"></path>
                    <path d="M15.486 247.069C13.776 238.917 10.363 236.333.228 235h15.258z"></path>
                    <path d="M148.931 219.413c0-16.797-13.616-30.413-30.413-30.413H-23c-12.702 0-23 10.297-23 23s10.298 23 23 23h171.931z"></path>
                    <path d="M232.277 258c0-12.703-10.297-23-23-23H15.485v15.587c0 16.797 13.617 30.413 30.413 30.413h163.379c12.703 0 23-10.297 23-23"></path>
                </g>
                <g fill="#fff" opacity=".28">
                    <path d="M1143.56 51.33c0-10.123 8.21-18.33 18.33-18.33h134.01c12.09 0 21.89 9.803 21.89 21.896v14.766h-155.9c-10.12 0-18.33-8.207-18.33-18.331"></path>
                    <path d="M1209.99 69.299h188.63c12.1 0 21.9 9.803 21.9 21.896v.855c0 12.093-9.8 21.896-21.9 21.896h-166.74c-12.09 0-21.89-9.803-21.89-21.896z"></path>
                    <rect width="217.793" height="32.669" x="1100" y="86.359" rx="16.334"></rect>
                    <path d="M1232.49 113.22h108.534v36.662H1232.49z"></path>
                    <rect width="203.999" height="34.484" x="1187.12" y="134.274" rx="17.242"></rect>
                    <path d="M1341.02 123.565c1.37-6.497 4.09-8.556 12.16-9.619h-12.16z"></path>
                    <path d="M1210.17 76.921c-1.37 6.498-4.09 8.557-12.16 9.62h12.16z"></path>
                    <path d="M1200.55 69.662c6.5 1.362 8.55 4.082 9.62 12.16v-12.16zM1350.64 134.456c-6.49-1.363-8.55-4.083-9.62-12.161v12.161zM1232.49 125.018c-1.36 6.497-4.08 8.556-12.16 9.619h12.16z"></path>
                    <path d="M1223.05 118.665c6.5 1.363 8.56 4.083 9.62 12.16v-12.16zM1327.41 69.843c-6.5-1.362-8.55-4.082-9.62-12.16v12.16z"></path>
                </g>
                <g fill="#fff" opacity=".15">
                    <path d="M475.346 34.159c-1.709 8.152-5.122 10.736-15.257 12.069h15.257z"></path>
                    <path d="M608.792 58.07c1.709-8.153 5.122-10.737 15.257-12.07h-15.257z"></path>
                    <path d="M475.346 30.413C475.346 13.616 488.963 0 505.759 0h141.518c12.703 0 23 10.298 23 23s-10.297 23-23 23H475.346z"></path>
                    <path d="M392 69c0-12.702 10.297-23 23-23h193.792v15.587c0 16.797-13.616 30.413-30.413 30.413H415c-12.703 0-23-10.297-23-23"></path>
                </g>
                <g fill="#fff" opacity=".18">
                    <path d="M1433.93 236.159c1.71 8.152 5.12 10.736 15.26 12.069h-15.26z"></path>
                    <path d="M1300.49 260.069c-1.71-8.152-5.13-10.736-15.26-12.069h15.26z"></path>
                    <path d="M1433.93 232.413c0-16.797-13.62-30.413-30.41-30.413H1262c-12.7 0-23 10.297-23 23s10.3 23 23 23h171.93z"></path>
                    <path d="M1517.28 271c0-12.703-10.3-23-23-23h-193.79v15.587c0 16.797 13.61 30.413 30.41 30.413h163.38c12.7 0 23-10.297 23-23"></path>
                </g>
            </svg>
        </div>
        <CustomContainer>
            <CustomColumn lg="12" md="8" sm="4" class="c-title__column">
                <AText as="h1" size="display-1" html={titleText} class="c-title__text" aria-label={title} />
            </CustomColumn>
        </CustomContainer>
    </div>

    {
        hasPoem && (
            <div class="c-title__poem | js-poem">
                <CustomContainer>
                    <CustomColumn lg="12" md="8" sm="4">
                        <div class="c-title__poem-wrapper">

                            {/* Stanzas */}
                            {poemStanzas?.map((stanza) => (
                                <div class="c-title__stanza-wrapper | js-stanza-wrapper">
                                    {stanza.text.map((block) => (
                                        <AText size="headline-1" class="c-title__poem-line">
                                            {block.children.map((child) => child.text).join("")}
                                        </AText>
                                    ))}
                                </div>
                            ))}

                            {/* Images as an independent layer, alternating sides */}
                            {images?.map((image, i) => {
                                return (
                                    <AImage image={image} class={`c-title__poem-image js-poem-image ${i % 2 === 0 ? "--left" : "--right"}`} />
                                );
                            })}

                        </div>
                    </CustomColumn>
                </CustomContainer>
            </div>
        )
    }
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { BaseComponent } from "../../helpers/base/BaseComponent";

    gsap.registerPlugin(ScrollTrigger);

    class CTitle extends BaseComponent {
        private freezeScrollY = 0;
        private poemTrigger?: ScrollTrigger;

        constructor(nodeInDOM: HTMLElement) {
            super(nodeInDOM);
            this.setupScrollFreeze();
            this.setupPoemScroll();
        }

        private setupScrollFreeze() {
            const el = this.nodeInDOM;
            if (el.getBoundingClientRect().height > window.innerHeight) {
                el.classList.add("--aling-bottom");
            } else {
                el.classList.add("--aling-top");
            }

            const placeholder = document.createElement("div");
            el.after(placeholder);

            const UNFREEZE_BUFFER = 10;

            const onScroll = () => {
                const isFrozen = el.classList.contains("is-frozen");

                if (!isFrozen) {
                    if (el.getBoundingClientRect().bottom <= window.innerHeight) {
                        this.freezeScrollY = window.scrollY;
                        placeholder.style.height = `${el.offsetHeight}px`;
                        el.classList.add("is-frozen");
                    }
                } else {
                    if (window.scrollY < this.freezeScrollY - UNFREEZE_BUFFER) {
                        placeholder.style.height = "0";
                        el.classList.remove("is-frozen");
                    }
                }
            };

            window.addEventListener("scroll", onScroll, { passive: true });
        }

        private setupPoemScroll() {
            const poem = this.nodeInDOM.querySelector<HTMLElement>(".js-poem");
            if (!poem) return;

            const stanzas = Array.from(poem.querySelectorAll<HTMLElement>(".js-stanza-wrapper"));
            const images = Array.from(poem.querySelectorAll<HTMLElement>(".js-poem-image"));

            if (stanzas.length === 0) return;

            //Set initial states
            gsap.set(stanzas, { autoAlpha: 0, scale: 0.8 });
            gsap.set(images, { autoAlpha: 0, translateY: '70vh' });

            const scrollTimeline = gsap.timeline({ paused: true });

            // ── Stanzas ──────────────────────────────────────────────
            stanzas.forEach((stanza, i) => {
                const isLast = i === stanzas.length - 1;

                scrollTimeline.fromTo(
                    stanza,
                    { autoAlpha: 0, scale: 0.8 },
                    { autoAlpha: 1, scale: 1, duration: 1, ease: "power2.out" }
                );

                // Last stanza stays visible — no exit tween
                if (!isLast) {
                    scrollTimeline.to(stanza, {
                        autoAlpha: 0,
                        scale: 1.1,
                        duration: 1,
                        ease: "power2.in",
                    });
                }
            });

            // ── Images ───────────────────────────────────────────────
            if (images.length > 0) {
                const totalDuration = scrollTimeline.duration();
                const enterDur  = 1.2;
                const exitDur   = 1.2;
                const holdDur   = 1.0;
                const imageSpan = enterDur + holdDur + exitDur;
                const stagger   = totalDuration / images.length;

                images.forEach((img, i) => {
                    const startTime = i * stagger;

                    scrollTimeline.fromTo(
                        img,
                        { translateY: '70vh' },
                        { translateY: '-70vh', duration: imageSpan, ease: "none" },
                        startTime
                    );

                    scrollTimeline.fromTo(
                        img,
                        { autoAlpha: 0 },
                        { autoAlpha: 1, duration: enterDur, ease: "power2.out" },
                        startTime
                    );

                    scrollTimeline.to(
                        img,
                        { autoAlpha: 0, duration: exitDur, ease: "power2.in" },
                        startTime + imageSpan - exitDur
                    );
                });
            }

            // ── ScrollTrigger ─────────────────────────────────────────
            let maxStanzaWidth = 0;

            const computeMaxStanzaWidth = () => {
                maxStanzaWidth = stanzas.reduce((max, stanza) => {
                    return Math.max(max, stanza.getBoundingClientRect().width);
                }, 0);
            };

            computeMaxStanzaWidth();

            const updateImagePositions = () => {
                const vw           = window.innerWidth;
                const imgWFallback = 200;
                const stanzaLeft   = vw / 2 - maxStanzaWidth / 2;
                const stanzaRight  = vw / 2 + maxStanzaWidth / 2;

                images.forEach((img) => {
                    const imgW = img.getBoundingClientRect().width || img.offsetWidth || imgWFallback;
                    img.style.right = "";

                    if (img.classList.contains("--left")) {
                        const centerX = stanzaLeft / 2;
                        img.style.left = `${Math.max(0, centerX - imgW / 2)}px`;
                    }

                    if (img.classList.contains("--right")) {
                        const centerX = (stanzaRight + vw) / 2;
                        img.style.left = `${Math.min(vw - imgW, centerX - imgW / 2)}px`;
                    }
                });
            };

            this.poemTrigger = ScrollTrigger.create({
                trigger: poem,
                animation: scrollTimeline,
                start: "top top",
                end: () => `+=${stanzas.length * window.innerHeight}`,
                pin: true,
                scrub: 0.5,
                invalidateOnRefresh: true,
                onUpdate: () => {
                    updateImagePositions();
                },
                onRefresh: () => {
                    computeMaxStanzaWidth();
                    updateImagePositions();
                },
            });

            // Ensure correct positioning on first paint
            updateImagePositions();

            window.addEventListener("resize", updateImagePositions, { passive: true });
        }
    }

    function initTitle() {
        BaseComponent.mountAll(".js-c-title", CTitle);
    }

    document.addEventListener("astro:page-load", initTitle);
</script>