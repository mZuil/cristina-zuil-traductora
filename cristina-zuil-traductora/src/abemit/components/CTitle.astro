                </g>
                <g fill="#fff" opacity=".28">
                    <path d="M1143.56 51.33c0-10.123 8.21-18.33 18.33-18.33h134.01c12.09 0 21.89 9.803 21.89 21.896v14.766h-155.9c-10.12 0-18.33-8.207-18.33-18.331" />
                    <path d="M1209.99 69.299h188.63c12.1 0 21.9 9.803 21.9 21.896v.855c0 12.093-9.8 21.896-21.9 21.896h-166.74c-12.09 0-21.89-9.803-21.89-21.896z" />
