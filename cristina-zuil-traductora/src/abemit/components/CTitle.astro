---
import CustomContainer from "../../helpers/structure/CustomContainer/CustomContainer.astro";
import CustomColumn from "../../helpers/structure/CustomColumn/CustomColumn.astro";
import AText from "../atoms/AText.astro";
import type { Text } from "../../helpers/interfaces/Text.astro";
import type { StrapiImage } from "../../helpers/interfaces/StrapiImage";
import AImage from "../atoms/AImage.astro";

interface Props {
    title: string;
    hasPoem: boolean;
    poemStanzas?: Text[];
    images?: StrapiImage[];
}

const { title, hasPoem, poemStanzas, images } = Astro.props;

let titleText = "";

if (!title) {
    throw new Error("Title is required");
} else {
    const titleParts = title.split(" ");
    titleText = `
        <span class="c-title__text-part --first" aria-hidden="true">${titleParts[0]}</span>
        <br aria-hidden="true">
        <span class="c-title__text-part --second" aria-hidden="true">${titleParts.slice(1).join(" ")}</span>
    `;
}
---

<style lang="scss">
    @use "../../styles/mixins" as *;

    .c-title {
        @include use-font(menu-item);

        position: relative;
        overflow: clip;
        background-color: var(--color-blue-light);
        z-index: 0;

        &.is-frozen {
            position: fixed;
            left: 0;
            right: 0;
            z-index: 0;

            &.--aling-top {
                top: 0;
            }

            &.--aling-bottom {
                bottom: 0;
            }
        }

        &__background {
            position: absolute;
            top: 7px;
            left: 0;
            right: 0;
            bottom: 0;
            overflow: hidden;

            &-svg {
                width: 100%;
            }
        }

        &__text {
            position: relative;
            padding-block: 215px 145px;
            text-align: center;

            &.--poem {
                padding-block: 215px 0;
            }

            :global(.c-title__text-part.--first) {
                color: var(--color-blue-dark);
            }

            :global(.c-title__text-part.--second) {
                color: var(--color-blue-default);
            }
        }

        // POEM
        &__poem {
            position: relative;
            height: 100dvh;
            opacity: 0;
            visibility: hidden;
        }

        &__poem-wrapper {
            height: 100dvh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: absolute;
            inset: 0;
        }

        &__stanza-wrapper {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;

            &.is-active {
                pointer-events: auto;
            }
        }

        &__poem-line {
            text-align: center;
        }

        // IMAGES
        &__poem-image {
            position: absolute;
            width: clamp(150px, 13.89vw, 400px);
            height: clamp(187.5px, 17.36vw, 500px);
            top: calc(50% - clamp(93.75px, 8.68vw, 250px));
            left: 0;
            object-fit: cover;
            pointer-events: none;
            border-radius: 15px;
        }

        //MOUSE
        &__mouse-scroll {
            position: fixed;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        &__mouse {
            width: clamp(18px, 1.5vw, 26px);
            height: clamp(30px, 2.4vw, 44px);
            border: 2px solid var(--color-grey);
            border-radius: clamp(12px, 1.1vw, 18px);
            position: relative;
        }

        &__wheel {
            width: clamp(2px, 0.2vw, 3px);
            height: clamp(6px, 0.55vw, 8px);
            background: var(--color-grey);
            border-radius: 2px;
            position: absolute;
            top: clamp(14px, 1.1vw, 18px);
            left: 50%;
            transform: translateX(-50%);
            animation: scroll 2.5s infinite;
        }

        @keyframes scroll {
            0%, 100% {
                top: clamp(14px, 1.1vw, 18px);
            }
            50% {
                top: clamp(5px, 0.45vw, 7px);
            }
        }

        &__scroll-arrow {
            display: block;
            rotate: 45deg;
            
            width: clamp(10px, 0.65vw, 14px);
            height: clamp(10px, 0.65vw, 14px);

            border-right: clamp(1px, 0.1vw, 2px) solid var(--color-grey);
            border-bottom: clamp(1px, 0.1vw, 2px) solid var(--color-grey);
            margin: 0 0 2px 1px;
            
            &.--first {
                animation: bounce 2.5s infinite 0.2s;
            }
            
            &.--second {
                animation: bounce 2.5s infinite 0.4s;
            }
            
            &.--third {
                animation: bounce 2.5s infinite 0.6s;
            }
        }

        @keyframes bounce {
            0%, 100% {
                transform: translate(0, 0);
            }
            50% {
                transform: translate(clamp(-4px, -0.35vw, -6px), clamp(-4px, -0.35vw, -6px));
            }
        }
    }
</style>

<section class="c-title js-c-title">
    <div class="c-title__blue-container | js-blue-container">
        <div class="c-title__background">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 1440 461" class="c-title__background-svg | js-background-svg">
                <g fill="#fff" opacity=".22">
                    <path d="M-76 122.191c0-22.091 17.909-40 40-40h210.278v43.663c0 22.091-17.908 40-40 40H-36c-22.091 0-40-17.909-40-40z" />
                    <path d="M114.722 106.652c0-13.51 10.951-24.46 24.461-24.46h201.356c13.51 0 24.461 10.95 24.461 24.46 0 13.509-10.951 24.461-24.461 24.461H139.183c-13.51 0-24.461-10.952-24.461-24.461" />
