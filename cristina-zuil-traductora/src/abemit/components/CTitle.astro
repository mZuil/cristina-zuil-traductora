                    <path d="M1232.49 113.22h108.534v36.662H1232.49z" />
                    <rect width="203.999" height="34.484" x="1187.12" y="134.274" rx="17.242" />
                    <path d="M1341.02 123.566c1.37-6.498 4.09-8.557 12.16-9.62h-12.16zM1210.17 76.922c-1.37 6.497-4.09 8.556-12.16 9.619h12.16z" />
                    <path d="M1200.55 69.662c6.5 1.362 8.55 4.082 9.62 12.16v-12.16zM1350.64 134.455c-6.49-1.362-8.55-4.082-9.62-12.16v12.16zM1232.49 125.018c-1.36 6.497-4.08 8.556-12.16 9.619h12.16z" />
                    <path d="M1223.05 118.665c6.5 1.363 8.56 4.083 9.62 12.16v-12.16zM1327.41 69.843c-6.5-1.362-8.55-4.082-9.62-12.16v12.16z" />
                </g>
                <g fill="#fff" opacity=".15">
                    <path d="M475.346 34.159c-1.709 8.152-5.122 10.736-15.257 12.069h15.257zM608.792 58.07c1.709-8.153 5.122-10.737 15.257-12.07h-15.257zM475.346 30.413C475.346 13.616 488.963 0 505.759 0h141.518c12.703 0 23 10.298 23 23s-10.297 23-23 23H475.346z" />
                    <path d="M392 69c0-12.703 10.297-23 23-23h193.792v15.587c0 16.797-13.616 30.413-30.413 30.413H415c-12.703 0-23-10.297-23-23" />
                </g>
                <g fill="#fff" opacity=".13">
                    <path d="M996 430.961c0-14.828 12.02-26.848 26.85-26.848h141.14v29.306c0 14.828-12.02 26.848-26.85 26.848h-114.29c-14.83 0-26.85-12.02-26.85-26.848z" />
                    <path d="M1124.01 420.531c0-9.068 7.35-16.418 16.42-16.418h135.15c9.07 0 16.42 7.35 16.42 16.418s-7.35 16.418-16.42 16.418h-135.15c-9.07 0-16.42-7.351-16.42-16.418" />
                    <path d="M1080.23 383.848c0-14.828 12.02-26.848 26.85-26.848h104.77c14.83 0 26.85 12.02 26.85 26.848v25.499h-158.47z" />
                    <path d="M1080.47 391.74c-1.79 8.518-5.35 11.218-15.94 12.611h15.94zM1162.56 449.56c1.79-8.519 5.35-11.218 15.94-12.611h-15.94zM1251.07 405.54c-8.51-1.786-11.21-5.352-12.61-15.942v15.942z" />
                </g>
                <g fill="#fff" opacity=".18">
                    <path d="M1433.93 236.158c1.71 8.153 5.12 10.737 15.26 12.07h-15.26zM1300.49 260.069c-1.71-8.152-5.13-10.736-15.26-12.069h15.26zM1433.93 232.413c0-16.797-13.62-30.413-30.41-30.413H1262c-12.7 0-23 10.297-23 23s10.3 23 23 23h171.93z" />
                    <path d="M1517.28 271c0-12.703-10.3-23-23-23h-193.79v15.587c0 16.797 13.61 30.413 30.41 30.413h163.38c12.7 0 23-10.297 23-23" />
                </g>
            </svg>
        </div>
        <CustomContainer>
            <CustomColumn lg="12" md="8" sm="4" class="c-title__column">
                <AText as="h1" size="display-1" html={titleText} class={`c-title__text ${hasPoem ? "--poem" : ""}`} aria-label={title} />
            </CustomColumn>
        </CustomContainer>
    </div>

    {
        hasPoem && (
            <div class="c-title__poem | js-poem">
                <CustomContainer>
                    <CustomColumn lg="12" md="8" sm="4">
                        <div class="c-title__poem-wrapper">

                            {/* Stanzas */}
                            {poemStanzas?.map((stanza) => (
                                <div class="c-title__stanza-wrapper | js-stanza-wrapper">
                                    {stanza.text.map((block) => (
                                        <AText size="headline-1" class="c-title__poem-line">
                                            {block.children.map((child) => child.text).join("")}
                                        </AText>
                                    ))}
                                </div>
                            ))}

                            {/* Images as an independent layer, alternating sides */}
                            {images?.map((image, i) => {
                                return (
                                    <AImage image={image} class={`c-title__poem-image js-poem-image ${i % 2 === 0 ? "--left" : "--right"}`} />
                                );
                            })}

                        </div>
                    </CustomColumn>
                </CustomContainer>
            </div>

            <div class="c-title__mouse-scroll js-scroll-arrow">
                <div class="c-title__mouse">
                    <div class="c-title__wheel"></div>
                </div>
                <div>
                    <span class="c-title__scroll-arrow --first"></span>
                    <span class="c-title__scroll-arrow --second"></span>
                    <span class="c-title__scroll-arrow --third"></span>
                </div>
            </div>
        )
    }
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { BaseComponent } from "../../helpers/base/BaseComponent";

    gsap.registerPlugin(ScrollTrigger);

    class CTitle extends BaseComponent {
        private freezeScrollY = 0;
        private poemTrigger?: ScrollTrigger;

        constructor(nodeInDOM: HTMLElement) {
            super(nodeInDOM);

            const poemTrigger = this.nodeInDOM.querySelector(".js-poem");

            if (poemTrigger) {
                //When everything is ready, make the poem visible
                gsap.set(poemTrigger, { autoAlpha: 1 });
            }

            this.setupBackground();
            this.setupScrollFreeze();
            this.setupPoemScroll();
        }

        /**
         * Sets up scroll freeze behavior for the title section.
         * When scrolling down and the element's bottom reaches the viewport bottom,
         * the element becomes "frozen" (fixed in place) while a placeholder maintains
         * the document flow. Scrolling up past a buffer threshold unfreezes it.
         */
        private setupScrollFreeze() {
            const el = this.nodeInDOM;

            // Determine vertical alignment based on element height vs viewport
            // If element is taller than viewport, align to bottom; otherwise align to top
            if (el.getBoundingClientRect().height > window.innerHeight) {
                el.classList.add("--aling-bottom");
            } else {
                el.classList.add("--aling-top");
            }

            // Create a placeholder element to maintain document height when element is frozen
            const placeholder = document.createElement("div");
            el.after(placeholder);

            // Buffer zone (in pixels) user must scroll up before unfreezing
            const UNFREEZE_BUFFER = 100;
            // Track last scroll position to determine scroll direction
            let lastScrollY = window.scrollY;

            // Initial freeze check: if element is top-aligned and page is at the top,
            // check if element should start in frozen state
            if (el.classList.contains("--aling-top") && window.scrollY <= 1) {
                const rect = el.getBoundingClientRect();
                // If element bottom is visible and within viewport, freeze it immediately
                if (rect.bottom <= window.innerHeight && rect.bottom > 0) {
                    this.freezeScrollY = window.scrollY;
                    placeholder.style.height = `${el.offsetHeight}px`;
                    el.classList.add("is-frozen");
                }
            }

            // Scroll event handler to manage freeze/unfreeze states
            const onScroll = () => {
                const currentScrollY = window.scrollY;
                const isScrollingDown = currentScrollY > lastScrollY;
                const rect = el.getBoundingClientRect();
                const isFrozen = el.classList.contains("is-frozen");

                if (!isFrozen) {
                    // FREEZE CONDITION: Scrolling down and element bottom reaches viewport bottom
                    if (isScrollingDown && rect.bottom <= window.innerHeight && rect.bottom > 0) {
                        // Store the scroll position where we froze
                        this.freezeScrollY = currentScrollY;
                        // Set placeholder height to maintain document flow
                        placeholder.style.height = `${el.offsetHeight}px`;
                        // Apply frozen state (CSS handles fixed positioning)
                        el.classList.add("is-frozen");
                    }
                } else {
                    // UNFREEZE CONDITION: Scrolling up past the freeze point minus buffer
                    if (!isScrollingDown && currentScrollY < this.freezeScrollY - UNFREEZE_BUFFER) {
                        // Remove placeholder height
                        placeholder.style.height = "0";
                        // Remove frozen state, element returns to normal flow
                        el.classList.remove("is-frozen");
                    }
                }

                // Update last scroll position for next comparison
                lastScrollY = currentScrollY;
            };

            // Attach scroll listener with passive flag for better performance
            window.addEventListener("scroll", onScroll, { passive: true });
        }

        private setupPoemScroll() {
            const poem = this.nodeInDOM.querySelector<HTMLElement>(".js-poem");
            if (!poem) return;

            const stanzas = Array.from(poem.querySelectorAll<HTMLElement>(".js-stanza-wrapper"));
            const images = Array.from(poem.querySelectorAll<HTMLElement>(".js-poem-image"));

            if (stanzas.length === 0) return;

            //Set initial states
            gsap.set(stanzas, { autoAlpha: 0, scale: 0.8 });
            gsap.set(images, { autoAlpha: 0, translateY: '70vh' });

            const scrollTimeline = gsap.timeline({ paused: true });

            //Make the mouse disappear when scrolling
            scrollTimeline.to(this.nodeInDOM.querySelector<HTMLElement>(".js-scroll-arrow"), { autoAlpha: 0, duration: 0.5 });

            // ── Stanzas ──────────────────────────────────────────────
            stanzas.forEach((stanza, i) => {
                const isLast = i === stanzas.length - 1;

                scrollTimeline.fromTo(
                    stanza,
                    { autoAlpha: 0, scale: 0.8 },
                    { autoAlpha: 1, scale: 1, duration: 1, ease: "power2.out" }
                );

                // Last stanza stays visible — no exit tween
                if (!isLast) {
                    scrollTimeline.to(stanza, {
                        autoAlpha: 0,
                        scale: 1.1,
                        duration: 1,
                        ease: "power2.in",
                    });
                }
            });

            // ── Images ───────────────────────────────────────────────
            if (images.length > 0) {
                const totalDuration = scrollTimeline.duration();
                const enterDur  = 1.2;
                const exitDur   = 1.2;
                const holdDur   = 1.0;
                const imageSpan = enterDur + holdDur + exitDur;
                const stagger   = totalDuration / images.length;

                images.forEach((img, i) => {
                    const startTime = i * stagger;

                    scrollTimeline.fromTo(
                        img,
                        { translateY: '70vh' },
                        { translateY: '-70vh', duration: imageSpan, ease: "none" },
                        startTime
                    );

                    scrollTimeline.fromTo(
                        img,
                        { autoAlpha: 0 },
                        { autoAlpha: 1, duration: enterDur, ease: "power2.out" },
                        startTime
                    );

                    scrollTimeline.to(
                        img,
                        { autoAlpha: 0, duration: exitDur, ease: "power2.in" },
                        startTime + imageSpan - exitDur
                    );
                });
            }

            // ── ScrollTrigger ─────────────────────────────────────────
            let maxStanzaWidth = 0;

            const computeMaxStanzaWidth = () => {
                maxStanzaWidth = stanzas.reduce((max, stanza) => {
                    return Math.max(max, stanza.getBoundingClientRect().width);
                }, 0);
            };

            computeMaxStanzaWidth();

            const updateImagePositions = () => {
                const vw           = window.innerWidth;
                const imgWFallback = 200;
                const stanzaLeft   = vw / 2 - maxStanzaWidth / 2;
                const stanzaRight  = vw / 2 + maxStanzaWidth / 2;

                images.forEach((img) => {
                    const imgW = img.getBoundingClientRect().width || img.offsetWidth || imgWFallback;
                    img.style.right = "";

                    if (img.classList.contains("--left")) {
                        const centerX = stanzaLeft / 2;
                        img.style.left = `${Math.max(0, centerX - imgW / 2)}px`;
                    }

                    if (img.classList.contains("--right")) {
                        const centerX = (stanzaRight + vw) / 2;
                        img.style.left = `${Math.min(vw - imgW, centerX - imgW / 2)}px`;
                    }
                });
            };

            this.poemTrigger = ScrollTrigger.create({
                trigger: poem,
                animation: scrollTimeline,
                start: "top top",
                end: () => `+=${stanzas.length * window.innerHeight}`,
                pin: true,
                scrub: 0.5,
                invalidateOnRefresh: true,
                onUpdate: () => {
                    updateImagePositions();
                },
                onRefresh: () => {
                    computeMaxStanzaWidth();
                    updateImagePositions();
                },
            });

            // Ensure correct positioning on first paint
            updateImagePositions();

            window.addEventListener("resize", updateImagePositions, { passive: true });
        }

        private setupBackground() {
            const svg = this.nodeInDOM.querySelector<SVGSVGElement>('.js-background-svg');
            if (!svg) return;

            const blueContainer = this.nodeInDOM.querySelector<HTMLElement>('.js-blue-container');
            const poem = this.nodeInDOM.querySelector<HTMLElement>('.js-poem');
            const stanzas = poem ? poem.querySelectorAll('.js-stanza-wrapper').length : 0;

            const TILE_HEIGHT = 461; // matches the original viewBox height
            const totalHeight = (blueContainer?.offsetHeight ?? 0) + (stanzas * window.innerHeight);
            const repetitions = Math.ceil(totalHeight / TILE_HEIGHT);

            // Grab the original groups before we start cloning
            const originalGroups = Array.from(svg.querySelectorAll<SVGGElement>(':scope > g'));

            for (let i = 1; i < repetitions; i++) {
                originalGroups.forEach(g => {
                    const clone = g.cloneNode(true) as SVGGElement;
                    clone.setAttribute('transform', `translate(0, ${i * TILE_HEIGHT})`);
                    svg.appendChild(clone);
                });
            }

            // Expand the viewBox so the new tiles are visible
            svg.setAttribute('viewBox', `0 0 1440 ${repetitions * TILE_HEIGHT}`);
            svg.removeAttribute('height');
        }
    }

    function initTitle() {
        BaseComponent.mountAll(".js-c-title", CTitle);
    }
    
    document.addEventListener("astro:page-load", initTitle);
</script>