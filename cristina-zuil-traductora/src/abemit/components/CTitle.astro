                </g>
                <g fill="#fff" opacity=".2">
                    <path d="M148.931 223.158c1.71 8.153 5.123 10.737 15.257 12.07h-15.257zM15.486 247.069C13.776 238.917 10.363 236.333.228 235h15.258zM148.931 219.413c0-16.797-13.616-30.413-30.413-30.413H-23c-12.702 0-23 10.297-23 23s10.298 23 23 23h171.931z" />
