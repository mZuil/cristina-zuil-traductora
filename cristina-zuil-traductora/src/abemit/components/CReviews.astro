---
import type { Publisher } from "../../helpers/interfaces/Publisher.astro";
import type { StrapiImage } from "../../helpers/interfaces/StrapiImage";
import AImage from "../atoms/AImage.astro";
import AText from "../atoms/AText.astro";

interface Props {
    publishers: Publisher[];
}

const { publishers = [] } = Astro.props as Props;

const getStrapiImageFromLogo = (
    logo: Publisher["logo"],
): StrapiImage | null => {
    if (!logo || typeof logo === "string") return null;

    const imgAttr =
        (logo as any)?.data?.attributes ?? (logo as any)?.attributes ?? logo;

    if (!imgAttr) return null;
    if (typeof imgAttr?.url !== "string" || !imgAttr.url) return null;
    if (
        typeof imgAttr?.width !== "number" ||
        typeof imgAttr?.height !== "number"
    )
        return null;
    if (typeof imgAttr?.mime !== "string" || !imgAttr.mime) return null;
    return imgAttr as StrapiImage;
};
---

<style lang="scss">
    @use "../../styles/mixins" as *;

    .c-reviews {
        // Card dimensions defined once, reused for both sizing and positioning
        --card-height: min(
            calc(clamp(280px, 32vw, 450px) * 68 / 50),
            calc(100svh - 15rem)
        );
        --card-width: calc(var(--card-height) * 50 / 68);

        position: relative;
        background-color: var(--color-white);
        z-index: 1;
        padding-block: 10px 0;

        @include lg {
            padding-block: 40px;
        }

        // ───────────────────────── Mobile / tablet (default) ─────────────────────────
        &__current-publisher {
            position: relative;
            width: 100%;
            height: auto;
            min-height: 250px;
            padding-inline: 1rem;
            padding-block: 0 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 2;
        }

        &__publisher-name {
            text-wrap: balance;
            text-align: center;
            // Reserve space for up to 3 lines so single-line names don't
            // cause the logo below to jump around.
            min-height: 3lh;
            display: flex;
            align-items: center;
            justify-content: center;

            @include sm {
                font-size: 24px;
            }
            
            @include md {
                font-size: 28px;
            }
        }

        &__publisher-logo {
            position: relative;
            margin-top: 14px;
            width: 140px;
            height: 70px;
        }

        &__publisher-logo-item {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            visibility: hidden;
            opacity: 0;

            &.is-active {
                visibility: visible;
                opacity: 1;
            }
        }

        :global(.c-reviews__publisher-logo-image) {
            width: 100%;
            height: 100%;
            max-height: 100px;
            object-fit: contain;
            object-position: center;

            @include lg {
                max-height: 160px;
            }
        }

        &__reviews-list {
            position: relative;
            list-style: none;
            margin: 0;
            padding-inline: 10vw;
            padding-top: 20px;
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 16px;
            overflow-x: auto;
            overflow-y: hidden;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;

            &::-webkit-scrollbar {
                display: none;
            }

            @include lg {
                padding-block: 8px;
            }
        }

        &__review {
            position: relative;
            display: flex;
            flex-direction: column;
            flex: 0 0 80vw;
            width: 80vw;
            aspect-ratio: 50 / 68;
            scroll-snap-align: center;
            will-change: transform;
            backface-visibility: hidden;
            border-radius: 30px;
            overflow: hidden;

            &::after {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(
                    0deg,
                    rgba(6, 12, 22, 0.95) 0%,
                    rgba(6, 12, 22, 0.75) 22%,
                    rgba(6, 12, 22, 0.25) 64%,
                    rgba(6, 12, 22, 0) 100%
                );
                border-radius: 30px;
            }
        }

        &__background-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 30px;

            @include lg {
                height: var(--card-height) !important;
            }
        }

        &__text {
            position: relative;
            padding: 27px 24px;
            margin-top: auto;
            z-index: 2;
            color: var(--color-white);

            @include sm {
                font-size: 18px;
            }
        }

        // Slightly bigger card on tablets
        @include md {
            &__review {
                flex: 0 0 60vw;
                width: 60vw;
            }

            &__reviews-list {
                padding-inline: 20vw;
            }
        }

        // ───────────────────────── Desktop (>= lg) ─────────────────────────
        @include lg {
            min-height: 100lvh;
            padding-block: 0;
            // The horizontal-scroll track (and its ScrollTrigger pin-spacer)
            // is wider than the viewport. Clip the overflow at the section
            // so it never bleeds white space to the right of the page.
            // `clip` (not `hidden`) avoids creating a scroll container and
            // does not establish a new containing block, so ScrollTrigger's
            // position:fixed pin keeps working normally.
            overflow-x: clip;

            &__current-publisher {
                position: absolute;
                inset-block: 0;
                left: 0;
                width: 33%;
                height: var(--card-height) !important;
                padding-inline: clamp(2rem, 5vw, 10rem);
                padding-block: 0;
            }

            &__publisher-logo {
                margin-top: 28px;
                width: 160px;
                height: 80px;
            }

            &__reviews-list {
                margin-left: calc(50vw - var(--card-width) / 2);
                padding-inline: 0;
                padding-block: 0;
                gap: var(--grid-gutter);
                overflow: visible;
                scroll-snap-type: none;
            }

            &__review {
                flex: 0 0 var(--card-width);
                width: var(--card-width);
                height: var(--card-height);
                scroll-snap-align: none;
            }
        }
    }

    .u-sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
</style>

<section class="c-reviews js-c-reviews" aria-label="Publisher testimonials">
    <!-- purely visual: screen readers use the cards instead -->
    <div class="c-reviews__current-publisher js-current-publisher" aria-hidden="true">
        <AText
            size="headline-1"
            class="c-reviews__publisher-name | js-publisher-name"
        >
            {publishers[0]?.name}
        </AText>
        <div class="c-reviews__publisher-logo js-publisher-logo">
            {
                publishers.map((publisher, idx) => {
                    const logoImage = getStrapiImageFromLogo(publisher.logo);
                    return logoImage ? (
                        <div
                            class={`c-reviews__publisher-logo-item js-publisher-logo-item${idx === 0 ? " is-active" : ""}`}
                            data-index={idx}
                        >
                            <AImage
                                image={logoImage}
                                sizes="220px"
                                loading="lazy"
                                class="c-reviews__publisher-logo-image"
                            />
                        </div>
                    ) : null;
                })
            }
        </div>
    </div>

    <ul class="c-reviews__reviews-list | js-reviews-list">
        {
            publishers.map((publisher, idx) => {
                const logoImage = getStrapiImageFromLogo(publisher.logo);
                return (
                    <li
                        class="c-reviews__review | js-review-item"
                        data-publisher={publisher?.name}
                        data-logo={logoImage?.url ?? ""}
                        aria-hidden={idx !== 0 ? "true" : "false"}
                        aria-label={publisher?.name}
                    >
                        {/*Visually hidden publisher name prefix for screen readers */}
                        <span class="u-sr-only">{publisher?.name}:</span>
                        <AImage image={publisher?.commentBgImage as StrapiImage} class="c-reviews__background-img" alt={publisher?.name} />
                        <AText size="subheading-2" class="c-reviews__text">
                            {publisher?.publisherComment}
                        </AText>
                    </li>
                );
            })
        }
    </ul>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { BaseComponent } from "../../helpers/base/BaseComponent";

    gsap.registerPlugin(ScrollTrigger);

    // Prevent layout jumps when the mobile URL bar shows/hides
    ScrollTrigger.config({ ignoreMobileResize: true });

    class CReviews extends BaseComponent {
        private st?: ScrollTrigger;
        private stPanel?: ScrollTrigger;
        private tl?: gsap.core.Timeline;
        private entranceTl?: gsap.core.Timeline;
        private activeIndex = -1;
        private publisherNameTween: gsap.core.Tween | null = null;
        private publisherLogoTween: gsap.core.Tween | null = null;
        private mm?: ReturnType<typeof gsap.matchMedia>;
        private mobileIO?: IntersectionObserver;
        private mobileOnResize?: () => void;
        private entranceIO?: IntersectionObserver;

        constructor(nodeInDOM: HTMLElement) {
            super(nodeInDOM);
            this.entranceAnimation();

            this.mm = gsap.matchMedia();

            // Desktop: pinned horizontal scroll timeline
            this.mm.add("(min-width: 1190px)", () => {
                this.initScrollCardsDesktop();
                return () => this.teardownDesktop();
            });

            // Mobile / tablet: native scroll-snap carousel with IntersectionObserver
            this.mm.add("(max-width: 1189px)", () => {
                this.initScrollCardsMobile();
                return () => this.teardownMobile();
            });
        }

        private getItemOffset(
            track: HTMLElement,
            firstItem: HTMLElement,
        ): number {
            const gap = parseFloat(
                getComputedStyle(track).columnGap ||
                    getComputedStyle(track).gap ||
                    "0",
            );
            return firstItem.offsetWidth + gap;
        }

        entranceAnimation() {
            const cards = this.nodeInDOM.querySelectorAll<HTMLElement>(".js-review-item");
            if (!cards.length) return;

            gsap.set(cards, { opacity: 0 });

            const play = () => {
                this.entranceTl?.kill();
                this.entranceTl = gsap.timeline();
                this.entranceTl.fromTo(
                    cards,
                    {
                        opacity: 0,
                        rotationY: -25,
                        rotationX: 8,
                        z: -200,
                        skewY: 2,
                        transformPerspective: 1000,
                        transformOrigin: "left center",
                    },
                    {
                        opacity: 1,
                        rotationY: 0,
                        rotationX: 0,
                        z: 0,
                        skewY: 0,
                        duration: 0.8,
                        ease: "power3.out",
                        stagger: 0.15,
                        overwrite: "auto",
                    },
                );
            };

            // Use IntersectionObserver instead of a ScrollTrigger here: it
            // reacts to the section's true viewport visibility and is immune
            // to other ScrollTriggers (e.g. CTitle's poem pin) injecting
            // pin-spacers that change the document height after mount.
            this.entranceIO?.disconnect();
            this.entranceIO = new IntersectionObserver(
                (entries) => {
                    for (const entry of entries) {
                        if (entry.isIntersecting) {
                            this.entranceIO?.disconnect();
                            this.entranceIO = undefined;
                            play();
                            break;
                        }
                    }
                },
                { rootMargin: "0px 0px -25% 0px", threshold: 0.01 },
            );
            this.entranceIO.observe(this.nodeInDOM);
        }

        private buildSetActive(
            items: HTMLElement[],
            publisherNameEl: HTMLElement | null,
            publisherLogoItems: HTMLElement[],
        ): (index: number) => void {
            return (index: number) => {
                const next = Math.max(0, Math.min(index, items.length - 1));
                if (next === this.activeIndex) return;
                this.activeIndex = next;

                items.forEach((el, i) => {
                    el.classList.toggle("is-active", i === next);
                });

                if (publisherNameEl) {
                    const nextName = items[next]?.dataset.publisher ?? "";
                    this.publisherNameTween?.kill();

                    gsap.set(publisherNameEl, { autoAlpha: 0 });
                    publisherNameEl.textContent = nextName;

                    this.publisherNameTween = gsap.to(publisherNameEl, {
                        autoAlpha: 1,
                        duration: 0.4,
                        overwrite: true,
                    });
                }

                if (publisherLogoItems.length > 0) {
                    this.publisherLogoTween?.kill();

                    publisherLogoItems.forEach((el, i) => {
                        if (i === next) return;
                        gsap.set(el, { autoAlpha: 0 });
                        el.classList.remove("is-active");
                    });

                    const nextLogo = publisherLogoItems[next];
                    if (nextLogo) {
                        nextLogo.classList.add("is-active");
                        this.publisherLogoTween = gsap.fromTo(
                            nextLogo,
                            { autoAlpha: 0 },
                            { autoAlpha: 1, duration: 0.4, overwrite: true },
                        );
                    }
                }
            };
        }

        private getReviewParts(): {
            track: HTMLElement;
            items: HTMLElement[];
            publisherNameEl: HTMLElement | null;
            publisherLogoItems: HTMLElement[];
            currentPublisher: HTMLElement | null;
        } | null {
            const track = this.nodeInDOM.querySelector<HTMLElement>(".js-reviews-list");
            if (!track) return null;

            const publisherNameEl =
                this.nodeInDOM.querySelector<HTMLElement>(".js-publisher-name");
            const publisherLogoItems = Array.from(
                this.nodeInDOM.querySelectorAll<HTMLElement>(".js-publisher-logo-item"),
            );

            const items = Array.from(
                track.querySelectorAll<HTMLElement>(".js-review-item"),
            );
            if (items.length <= 1) return null;

            const currentPublisher =
                this.nodeInDOM.querySelector<HTMLElement>(".js-current-publisher");

            return { track, items, publisherNameEl, publisherLogoItems, currentPublisher };
        }

        private initScrollCardsDesktop() {
            const parts = this.getReviewParts();
            if (!parts) return;
            const { track, items, publisherNameEl, publisherLogoItems, currentPublisher } = parts;

            items.forEach((item, i) => {
                item.style.zIndex = String(i + 1);
                item.style.transform = "";
            });

            const setActive = this.buildSetActive(items, publisherNameEl, publisherLogoItems);

            if (publisherNameEl) {
                publisherNameEl.textContent =
                    items[0]?.dataset.publisher ??
                    publisherNameEl.textContent ??
                    "";
                gsap.set(publisherNameEl, { autoAlpha: 1 });
            }

            this.activeIndex = -1;
            setActive(0);

            this.tl?.kill();
            this.tl = gsap.timeline({ paused: true });

            items.forEach((item, i) => {
                if (i === 0) return;
                this.tl!.to(
                    item,
                    {
                        x: () => -(i * this.getItemOffset(track, items[0])),
                        ease: "none",
                        duration: i,
                    },
                    0,
                );
            });

            const endDistance = () =>
                `+=${(items.length - 1) * this.getItemOffset(track, items[0]) + window.innerHeight}`;

            this.st?.kill(true);
            this.st = ScrollTrigger.create({
                trigger: track,
                start: "center center",
                end: endDistance,
                animation: this.tl,
                pin: track,
                pinSpacing: true,
                anticipatePin: 1,
                scrub: true,
                invalidateOnRefresh: true,
                onEnter: () => {
                    if (this.entranceTl && this.entranceTl.progress() < 1) {
                        this.entranceTl.progress(1);
                        this.entranceTl.kill();
                        this.entranceTl = undefined;
                        gsap.set(items, {
                            opacity: 1,
                            rotationY: 0,
                            rotationX: 0,
                            z: 0,
                            skewY: 0,
                        });
                    }
                },
                onUpdate: () => {
                    if (!this.tl) return;
                    const t = this.tl.time();
                    const idx = Math.min(items.length - 1, Math.floor(t + 0.5));
                    setActive(idx);
                },
                onRefresh: () => {
                    if (!this.tl) return;
                    const t = this.tl.time();
                    const idx = Math.min(items.length - 1, Math.floor(t + 0.5));
                    setActive(idx);
                },
            });

            if (currentPublisher) {
                this.stPanel?.kill(true);
                this.stPanel = ScrollTrigger.create({
                    trigger: track,
                    start: "center center",
                    end: endDistance,
                    pin: currentPublisher,
                    pinSpacing: false,
                    anticipatePin: 1,
                    invalidateOnRefresh: true,
                });
            }
        }

        private teardownDesktop() {
            this.st?.kill(true);
            this.st = undefined;
            this.stPanel?.kill(true);
            this.stPanel = undefined;
            this.tl?.kill();
            this.tl = undefined;

            // Reset any inline transforms applied by the timeline
            const items = this.nodeInDOM.querySelectorAll<HTMLElement>(".js-review-item");
            items.forEach((el) => {
                el.style.transform = "";
            });
        }

        private initScrollCardsMobile() {
            const parts = this.getReviewParts();
            if (!parts) return;
            const { track, items, publisherNameEl, publisherLogoItems } = parts;

            items.forEach((item, i) => {
                item.style.zIndex = String(i + 1);
                item.style.transform = "";
            });

            const setActive = this.buildSetActive(items, publisherNameEl, publisherLogoItems);

            if (publisherNameEl) {
                publisherNameEl.textContent =
                    items[0]?.dataset.publisher ??
                    publisherNameEl.textContent ??
                    "";
                gsap.set(publisherNameEl, { autoAlpha: 1 });
            }

            this.activeIndex = -1;
            setActive(0);

            // Track viewport size to ignore IO callbacks caused only by the
            // mobile URL bar showing/hiding (height-only resizes). Without
            // this, the reflow flips bestIdx between adjacent cards and the
            // publisher name/logo flicker.
            let lastWidth = window.innerWidth;
            let lastHeight = window.innerHeight;
            let suppressUntil = 0;

            const onViewportResize = () => {
                const w = window.innerWidth;
                const h = window.innerHeight;
                if (w === lastWidth && h !== lastHeight) {
                    // Address-bar toggle: suppress IO updates for a short window
                    suppressUntil = performance.now() + 400;
                }
                lastWidth = w;
                lastHeight = h;
            };
            window.addEventListener("resize", onViewportResize, { passive: true });
            this.mobileOnResize = onViewportResize;

            // Use an IntersectionObserver against the scroll container to pick
            // whichever card is most visible (>= 60% threshold).
            this.mobileIO?.disconnect();
            this.mobileIO = new IntersectionObserver(
                (entries) => {
                    if (performance.now() < suppressUntil) return;

                    let bestIdx = -1;
                    let bestRatio = 0;
                    entries.forEach((entry) => {
                        if (entry.intersectionRatio > bestRatio) {
                            bestRatio = entry.intersectionRatio;
                            bestIdx = items.indexOf(entry.target as HTMLElement);
                        }
                    });
                    if (bestIdx >= 0 && bestRatio >= 0.6) {
                        setActive(bestIdx);
                    }
                },
                {
                    root: track,
                    threshold: [0, 0.25, 0.5, 0.6, 0.75, 1],
                },
            );

            items.forEach((item) => this.mobileIO!.observe(item));
        }

        private teardownMobile() {
            this.mobileIO?.disconnect();
            this.mobileIO = undefined;
            if (this.mobileOnResize) {
                window.removeEventListener("resize", this.mobileOnResize);
                this.mobileOnResize = undefined;
            }
        }

        destroy(): void {
            this.mm?.revert();
            this.mm = undefined;

            this.st?.kill(true);
            this.st = undefined;
            this.stPanel?.kill(true);
            this.stPanel = undefined;
            this.tl?.kill();
            this.tl = undefined;
            this.entranceTl?.kill();
            this.entranceTl = undefined;
            this.publisherNameTween?.kill();
            this.publisherNameTween = null;
            this.publisherLogoTween?.kill();
            this.publisherLogoTween = null;
            this.mobileIO?.disconnect();
            this.mobileIO = undefined;
            this.entranceIO?.disconnect();
            this.entranceIO = undefined;
        }
    }

    function initReviews() {
        const instances = BaseComponent.mountAll(".js-c-reviews", CReviews);
        const cleanup = () => instances.forEach((i) => (i as any).destroy?.());
        document.addEventListener("astro:before-swap", cleanup, { once: true });
    }

    document.addEventListener("astro:page-load", initReviews);
</script>