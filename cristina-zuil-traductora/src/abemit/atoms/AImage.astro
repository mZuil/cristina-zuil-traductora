---
/**
 * AImage
 *
 * A polymorphic image component for Strapi media library assets.
 *
 * It renders a <picture> element with:
 *   1. AVIF srcset  — generated by the image-optimizer plugin (best compression)
 *   2. WebP srcset  — generated by the image-optimizer plugin (broad support)
 *   3. Native <img> — original JPEG/PNG from Strapi's formats (fallback)
 *
 * The browser automatically picks the best format + size it can handle.
 *
 * Required prop: `image` — the raw Strapi image object from your API response.
 * Optional:
 *   `sizes`        — override the default `sizes` attribute to match your layout.
 *                    e.g. "(max-width: 768px) 100vw, 50vw"
 *   `loading`      — 'lazy' (default) | 'eager' (use 'eager' for LCP images)
 *   `fetchpriority`— 'high' | 'low' | 'auto' (use 'high' for above-the-fold)
 *   `aspect`       — CSS aspect-ratio shorthand, e.g. '16/9', '1/1', '4/3'
 *                    When set, the image fills the container with object-fit: cover.
 *   `fit`          — object-fit value when `aspect` is provided (default: 'cover')
 *   `withWrapper`  — wraps the <picture> in a <div class="a-image-wrapper ...">
 *
 * ⚠️  SVG images are passed through as a plain <img> — no format variants exist.
 */

import type { StrapiImage } from '../../helpers/interfaces/StrapiImage';
import { buildSrcSet, buildNativeSrcSet, DEFAULT_SIZES } from '../../helpers/interfaces/StrapiImage';

interface Props {
  image: StrapiImage;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  aspect?: string;
  fit?: 'cover' | 'contain' | 'fill' | 'none' | 'scale-down';
  class?: string;
  pictureClass?: string;
  wrapperClass?: string;
  withWrapper?: boolean;
  [key: string]: unknown;
}

const {
  image,
  sizes          = DEFAULT_SIZES,
  loading        = 'lazy',
  fetchpriority,
  aspect,
  fit            = 'cover',
  class: className       = '',
  pictureClass           = '',
  wrapperClass           = '',
  withWrapper            = false,
  ...rest
} = Astro.props;

const isSvg    = image.mime === 'image/svg+xml';
const hasFormats = !isSvg && !!image.formats && Object.keys(image.formats).length > 0;

const avifSrcSet   = !isSvg ? buildSrcSet(image, 'avif') : '';
const webpSrcSet   = !isSvg ? buildSrcSet(image, 'webp') : '';
const nativeSrcSet = hasFormats ? buildNativeSrcSet(image) : '';

const STRAPI_URL   = import.meta.env.PUBLIC_STRAPI_URL ?? '';
const src          = `${STRAPI_URL}${image.url}`;
const alt          = image.alternativeText ?? image.name ?? '';

const imgClasses = [
  'a-image',
  aspect ? '--has-aspect' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const pictureClasses = ['a-image__picture', pictureClass]
  .filter(Boolean)
  .join(' ');

const wrapperClasses = ['a-image-wrapper', wrapperClass]
  .filter(Boolean)
  .join(' ');

// Inline CSS variable for aspect + fit — only injected when `aspect` is set
const imgStyle = aspect
  ? `--a-image-aspect: ${aspect}; --a-image-fit: ${fit};`
  : undefined;
---

<style lang="scss">
  .a-image-wrapper {
    display: contents; // transparent wrapper — lay out with parent grid/flex
  }

  .a-image__picture {
    display: block;
    line-height: 0; // collapse inline gap under the <img>
  }

  .a-image {
    display: block;
    max-width: 100%;
    height: auto;

    //When an explicit aspect-ratio is requested the image fills its box
    &.--has-aspect {
      width: 100%;
      height: 100%;
      aspect-ratio: var(--a-image-aspect);
      object-fit: var(--a-image-fit, cover);
      object-position: center;
    }
  }
</style>

{withWrapper ? (
  <div class={wrapperClasses}>
    {isSvg ? (
      <img class={imgClasses} src={src} alt={alt} width={image.width} height={image.height} loading={loading} fetchpriority={fetchpriority} style={imgStyle} {...rest} />
    ) : (
      <picture class={pictureClasses}>
        {avifSrcSet && (<source type="image/avif" srcset={avifSrcSet} {sizes} />)}
        {webpSrcSet && (<source type="image/webp" srcset={webpSrcSet} {sizes} />)}
        {nativeSrcSet && (<source srcset={nativeSrcSet} {sizes} />)}
        <img class={imgClasses} src={src} alt={alt} width={image.width} height={image.height} loading={loading} fetchpriority={fetchpriority} style={imgStyle} {...rest} />
      </picture>
    )}
  </div>
) : (
  <>
    {isSvg ? (
      <img
        class={imgClasses}
        src={src}
        alt={alt}
        width={image.width}
        height={image.height}
        loading={loading}
        fetchpriority={fetchpriority}
        style={imgStyle}
        {...rest}
      />
    ) : (
      <picture class={pictureClasses}>
        {avifSrcSet && (
          <source type="image/avif" srcset={avifSrcSet} {sizes} />
        )}
        {webpSrcSet && (
          <source type="image/webp" srcset={webpSrcSet} {sizes} />
        )}
        {nativeSrcSet && (
          <source srcset={nativeSrcSet} {sizes} />
        )}
        <img
          class={imgClasses}
          src={src}
          alt={alt}
          width={image.width}
          height={image.height}
          loading={loading}
          fetchpriority={fetchpriority}
          style={imgStyle}
          {...rest}
        />
      </picture>
    )}
  </>
)}