---
interface Props {
  as?: 'button' | 'a';
  variant?: 'primary' | 'secondary' | 'ghost' | 'danger' | 'outline';
  size?: string;
  href?: string;
  target?: string;
  onClick?: string;
  class?: string;
  wrapperClass?: string;
  withWrapper?: boolean;
  type?: 'button' | 'submit' | 'reset';
  [key: string]: unknown;
}

const {
  as = 'button',
  variant,
  size = 'body',
  href,
  target,
  onClick,
  class: className = '',
  wrapperClass = '',
  withWrapper = false,
  type = 'button',
  ...rest
} = Astro.props;

const isActive =
  as === 'a' && href
    ? Astro.url.pathname === href || Astro.url.pathname.startsWith(href + '/')
    : false;

const isPrimary = variant === 'primary';

const elementClasses = [
  'a-button',
  variant  ? `--${variant}`   : '',
  size     ? `v-font-${size}` : '',
  isActive ? 'is-active'      : '',
  isPrimary ? 'a-button--ripple' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const wrapperClasses = ['b-button-wrapper', wrapperClass]
  .filter(Boolean)
  .join(' ');
---

{(() => {
  const inner = isPrimary ? (
    <>
      <span class="a-button__bg" aria-hidden="true"></span>
      <span class="a-button__bg-circle" aria-hidden="true">
        <span data-ripple-circle class="a-button__circle-wrap">
          <span class="a-button__circle"></span>
        </span>
      </span>
      <span class="a-button__inner">
        <slot />
      </span>
    </>
  ) : (
    <slot />
  );

  const sharedAProps = {
    class: elementClasses,
    href,
    target,
    rel: target === '_blank' ? 'noopener noreferrer' : undefined,
    'aria-current': isActive ? ('page' as const) : undefined,
    ...rest,
  };

  const sharedBtnProps = {
    class: elementClasses,
    type,
    onclick: onClick,
    ...rest,
  };

  if (withWrapper) {
    return (
      <div class={wrapperClasses}>
        {as === 'a'
          ? <a {...sharedAProps}>{inner}</a>
          : <button {...sharedBtnProps}>{inner}</button>
        }
      </div>
    );
  }

  return as === 'a'
    ? <a {...sharedAProps}>{inner}</a>
    : <button {...sharedBtnProps}>{inner}</button>;
})()}

{isPrimary && (
  <script>
    import { initRipple } from '../../scripts/ripple';

    document.addEventListener('astro:page-load', () => {
      document.fonts.ready.then(initRipple);
    });
  </script>
)}