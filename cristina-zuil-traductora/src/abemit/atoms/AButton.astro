---
/**
 * AButton
 *
 * A polymorphic button/link component.
 *
 * `as` prop:
 *   - 'button' → <button> element, use `onClick` (inline string handler)
 *   - 'a'      → <a> element, use `href` + optional `target`.
 *                Automatically adds aria-current="page" and `is-active` class
 *                when `href` matches the current URL — no separate "link" type needed.
 *
 * ⚠️  Astro components are server-rendered, so you cannot pass a JS function
 *     as a prop. For `onClick`, pass an inline string handler (e.g. onClick="doSomething()")
 *     or add a <script> / data-* attribute in the parent and use event delegation.
 */

interface Props {
  as?: 'button' | 'a';
  variant?: 'primary' | 'secondary' | 'ghost' | 'danger' | 'outline';
  size?: string;
  href?: string;
  target?: string;
  onClick?: string;
  class?: string;
  wrapperClass?: string;
  withWrapper?: boolean;
  type?: 'button' | 'submit' | 'reset';
  [key: string]: unknown;
}

const {
  as = 'button',
  variant,
  size = 'body',
  href,
  target,
  onClick,
  class: className = '',
  wrapperClass = '',
  withWrapper = false,
  type = 'button',
  ...rest
} = Astro.props;

const isActive = as === 'a' && href ? Astro.url.pathname === href || Astro.url.pathname.startsWith(href + '/'): false;

const elementClasses = [
  'a-button',
  variant  ? `--${variant}` : '',
  size     ? `v-font-${size}`        : '',
  isActive ? 'is-active'             : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const wrapperClasses = ['b-button-wrapper', wrapperClass]
  .filter(Boolean)
  .join(' ');
---

<style lang="scss">
    .a-button {

        text-decoration: none;
        color: inherit;
        
        &.--primary {
            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            gap: 10px;

            padding: 13px 27px;
            background-color: var(--color-blue-default);
            color: var(--color-white);
            border: none;
            border-radius: 30px;
            cursor: pointer;
            transition: background-color 0.2s ease-in-out;

            &:hover {
                background-color: var(--color-blue-dark);
            }

            &:focus-visible {
                outline: 2px solid var(--color-blue-dark);
                outline-offset: 2px;
            }

            &.--has-icon {
                padding: 13px 27px 13px 20px;
            }
        }
    }
</style>

{withWrapper ? (
  <div class={wrapperClasses}>
    {as === 'a' ? (
      <a class={elementClasses} href={href} target={target} rel={target === '_blank' ? 'noopener noreferrer' : undefined} aria-current={isActive ? 'page' : undefined} {...rest}>
        <slot />
      </a>
    ) : (
      <button class={elementClasses} type={type} onclick={onClick} {...rest}>
        <slot />
      </button>
    )}
  </div>
) : (
  <>
    {as === 'a' ? (
      <a class={elementClasses} href={href} target={target} rel={target === '_blank' ? 'noopener noreferrer' : undefined} aria-current={isActive ? 'page' : undefined} {...rest}>
        <slot />
      </a>
    ) : (
      <button type={type} class={elementClasses} onclick={onClick} {...rest}>
        <slot />
      </button>
    )}
  </>
)}