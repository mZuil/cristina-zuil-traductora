---
import { designTokens, getFontStyle } from '../../config/design-tokens';

// Generate CSS variables from design tokens
const cssVars: string[] = [];

// Colors
const colors = designTokens.colors as Record<string, string>;
for (const key in colors) {
  if (colors.hasOwnProperty(key)) {
    cssVars.push(`  --color-${key}: ${colors[key]};`);
  }
}

// Breakpoints
const breakpoints = designTokens.breakpoints;
for (const key in breakpoints) {
  if (breakpoints.hasOwnProperty(key)) {
    const value = breakpoints[key as keyof typeof breakpoints];
    cssVars.push(`  --breakpoint-${key}: ${value.breakpoint};`);
    cssVars.push(`  --grid-columns-${key}: ${value.columns};`);
    cssVars.push(`  --grid-gap-${key}: ${value.gap};`);
    cssVars.push(`  --container-padding-${key}: ${value.padding};`);
  }
}

// Container max-width (separate from breakpoints)
cssVars.push(`  --container-max-width: ${designTokens.containerMaxWidth};`);

// Container inner width (default)
cssVars.push(`  --container-inner-width: 100%;`);

// Font families
const fontFamilies = designTokens.fonts.families as Record<string, string>;
for (const key in fontFamilies) {
  if (fontFamilies.hasOwnProperty(key)) {
    cssVars.push(`  --font-family-${key}: ${fontFamilies[key]};`);
  }
}

const fontStyleVarsSm: string[] = [];
const fontStyleVarsMd: string[] = [];
const fontStyleVarsLg: string[] = [];

const fontStyleUtilityClasses: string[] = [];
const fontStyleNames = Object.keys(designTokens.fonts.styles) as Array<keyof typeof designTokens.fonts.styles>;

for (const styleName of fontStyleNames) {
  const smStyle = getFontStyle(styleName, 'sm');
  const mdStyle = getFontStyle(styleName, 'md');
  const lgStyle = getFontStyle(styleName, 'lg');

  fontStyleVarsSm.push(`  --font-style-${styleName}-font-family: ${smStyle.fontFamily};`);
  fontStyleVarsSm.push(`  --font-style-${styleName}-font-size: ${smStyle.fontSize};`);
  fontStyleVarsSm.push(`  --font-style-${styleName}-font-weight: ${smStyle.fontWeight};`);
  fontStyleVarsSm.push(`  --font-style-${styleName}-line-height: ${smStyle.lineHeight};`);
  fontStyleVarsSm.push(`  --font-style-${styleName}-letter-spacing: ${smStyle.letterSpacing};`);

  fontStyleVarsMd.push(`  --font-style-${styleName}-font-family: ${mdStyle.fontFamily};`);
  fontStyleVarsMd.push(`  --font-style-${styleName}-font-size: ${mdStyle.fontSize};`);
  fontStyleVarsMd.push(`  --font-style-${styleName}-font-weight: ${mdStyle.fontWeight};`);
  fontStyleVarsMd.push(`  --font-style-${styleName}-line-height: ${mdStyle.lineHeight};`);
  fontStyleVarsMd.push(`  --font-style-${styleName}-letter-spacing: ${mdStyle.letterSpacing};`);

  fontStyleVarsLg.push(`  --font-style-${styleName}-font-family: ${lgStyle.fontFamily};`);
  fontStyleVarsLg.push(`  --font-style-${styleName}-font-size: ${lgStyle.fontSize};`);
  fontStyleVarsLg.push(`  --font-style-${styleName}-font-weight: ${lgStyle.fontWeight};`);
  fontStyleVarsLg.push(`  --font-style-${styleName}-line-height: ${lgStyle.lineHeight};`);
  fontStyleVarsLg.push(`  --font-style-${styleName}-letter-spacing: ${lgStyle.letterSpacing};`);

  fontStyleUtilityClasses.push(`.v-font-${styleName} {\n  font-family: var(--font-style-${styleName}-font-family);\n  font-size: var(--font-style-${styleName}-font-size);\n  font-weight: var(--font-style-${styleName}-font-weight);\n  line-height: var(--font-style-${styleName}-line-height);\n  letter-spacing: var(--font-style-${styleName}-letter-spacing);\n}`);
}

// Responsive variables for each breakpoint
// sm: < 610px, md: 610px - 1190px, lg: >= 1191px
const { sm, md, lg } = designTokens.breakpoints;
const mdBreakpoint = md.breakpoint; // 610px
const lgBreakpoint = lg.breakpoint; // 1191px

const mdStart = Number.parseInt(mdBreakpoint, 10) || 610;
const lgStart = Number.parseInt(lgBreakpoint, 10) || 1191;
const mdEnd = lgStart - 1;

let customColumnRules = '';

for (let i = 1; i <= sm.columns; i++) {
  customColumnRules += `custom-column[sm="${i}"] {\n  width: calc(var(--width-col) * ${i} + var(--grid-gutter) * (${i} - 1));\n}\n\n`;
}

for (let i = 1; i <= sm.columns; i++) {
  customColumnRules += `custom-column[sm-push="${i}"] {\n  margin-left: calc(var(--width-col) * ${i} + var(--grid-gutter) * ${i});\n}\n\n`;
}

customColumnRules += `@media (min-width: ${mdStart}px) and (max-width: ${mdEnd}px) {\n`;
for (let i = 1; i <= md.columns; i++) {
  customColumnRules += `  custom-column[md="${i}"] {\n    width: calc(var(--width-col) * ${i} + var(--grid-gutter) * (${i} - 1));\n  }\n\n`;
}

for (let i = 1; i <= md.columns; i++) {
  customColumnRules += `  custom-column[md-push="${i}"] {\n    margin-left: calc(var(--width-col) * ${i} + var(--grid-gutter) * ${i});\n  }\n\n`;
}
customColumnRules += `}\n\n`;

customColumnRules += `@media (min-width: ${lgStart}px) {\n`;
for (let i = 1; i <= lg.columns; i++) {
  customColumnRules += `  custom-column[lg="${i}"] {\n    width: calc(var(--width-col) * ${i} + var(--grid-gutter) * (${i} - 1));\n  }\n\n`;
}

for (let i = 1; i <= lg.columns; i++) {
  customColumnRules += `  custom-column[lg-push="${i}"] {\n    margin-left: calc(var(--width-col) * ${i} + var(--grid-gutter) * ${i});\n  }\n\n`;
}
customColumnRules += `}\n`;

const cssVariables = `:root {
${cssVars.join('\n')}
}

/* Small breakpoint (default, < 610px) */
:root {
  --total-columns: ${sm.columns};
  --grid-gutter: ${sm.gap};
  --container-padding: ${sm.padding};
  --width-col: calc((var(--container-inner-width) - var(--grid-gutter) * (var(--total-columns) - 1)) / var(--total-columns));
${fontStyleVarsSm.join('\n')}
}

/* Medium breakpoint (610px - 1190px) */
@media (min-width: ${mdBreakpoint}) and (max-width: 1190px) {
  :root {
    --total-columns: ${md.columns};
    --grid-gutter: ${md.gap};
    --container-padding: ${md.padding};
    --width-col: calc((var(--container-inner-width) - var(--grid-gutter) * (var(--total-columns) - 1)) / var(--total-columns));
${fontStyleVarsMd.join('\n')}
  }
}

/* Large breakpoint (>= 1191px) */
@media (min-width: ${lgBreakpoint}) {
  :root {
    --total-columns: ${lg.columns};
    --grid-gutter: ${lg.gap};
    --container-padding: ${lg.padding};
    --width-col: calc((var(--container-inner-width) - var(--grid-gutter) * (var(--total-columns) - 1)) / var(--total-columns));
${fontStyleVarsLg.join('\n')}
  }
  
  /* Update container inner width when viewport exceeds max-width */
  :root {
    --container-inner-width: min(100dvw - 2 * var(--container-padding), var(--container-max-width));
    --width-col: calc((var(--container-inner-width) - var(--grid-gutter) * (var(--total-columns) - 1)) / var(--total-columns));
  }
}

${customColumnRules}`;

---

<style is:global set:html={cssVariables}></style>

<style is:global set:html={fontStyleUtilityClasses.join('\n\n')}></style>